rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function isPlatformAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'platform_admin';
    }
    function isClubMember(clubId) {
      return isAuth() && exists(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid));
    }
    function isClubAdmin(clubId) {
      return isAuth() && exists(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid))
        && get(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid)).data.role == 'admin';
    }
    function hasEventInvite(eventId) {
      return isAuth() && exists(/databases/$(database)/documents/event_invites/$(eventId + '_' + request.auth.uid));
    }
    function eventClubId(eventId) {
      return get(/databases/$(database)/documents/club_events/$(eventId)).data.club_id;
    }
    // Permissão granular de um membro comum para editar os pets do clube
    // (admins já podem via isClubAdmin, independente desta flag).
    function canEditClubPets(clubId) {
      return isAuth() && exists(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid))
        && get(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid)).data.get('permissions', {}).get('edit_pets', false) == true;
    }
    // Permissão granular do painel de administração da organização
    // (`animals`, `finance`, `donations`, `feed`, `team` — ver
    // src/modules/organizations/domain/permissions.js). Admins já têm tudo
    // via isClubAdmin, independente desta flag.
    function hasClubPermission(clubId, key) {
      return isAuth() && exists(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid))
        && get(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid)).data.get('permissions', {}).get(key, false) == true;
    }
    // Proprietário do clube (dono de todas as permissões, protegido contra
    // remoção/rebaixamento por outros admins — ver domain/permissions.js).
    function isClubOwnerUid(clubId, uid) {
      return exists(/databases/$(database)/documents/clubs/$(clubId))
        && get(/databases/$(database)/documents/clubs/$(clubId)).data.created_by == uid;
    }
    // Quem pode gerenciar um pet (dono pessoa física, ou clube dono via admin/permissão).
    function canManagePet(petData) {
      return petData.owner_id == request.auth.uid ||
        (petData.get('owner_type', '') == 'organization' && (
          isClubAdmin(petData.owner_id) || canEditClubPets(petData.owner_id) || hasClubPermission(petData.owner_id, 'animals')
        ));
    }
    // Dono fixo da plataforma (bootstrap do primeiro platform_admin) — espelha
    // a mesma checagem por e-mail já feita no client (FirebaseAuthContext).
    function isPlatformOwnerAuth() {
      return isAuth() && request.auth.token.email != null
        && request.auth.token.email.lower() == 'fsalamoni@gmail.com';
    }

    // ─── Usuários ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();
      // role só pode ser 'platform_admin' na criação se for o dono fixo da
      // plataforma — evita que qualquer usuário se autopromova a admin.
      allow create: if isOwner(userId) && (
        request.resource.data.get('role', 'user') == 'user' ||
        (request.resource.data.role == 'platform_admin' && isPlatformOwnerAuth())
      );
      // O próprio usuário só edita seu perfil; role/banimento são imutáveis
      // por ele mesmo (exceto o bootstrap do dono fixo), só um platform_admin
      // pode banir/desbanir ou alterar papéis.
      allow update: if isPlatformAdmin() || (
        isOwner(userId) &&
        (request.resource.data.get('role', 'user') == resource.data.get('role', 'user') ||
          (request.resource.data.role == 'platform_admin' && isPlatformOwnerAuth())) &&
        request.resource.data.get('banned', false) == resource.data.get('banned', false) &&
        request.resource.data.get('banned_at', null) == resource.data.get('banned_at', null) &&
        request.resource.data.get('banned_reason', null) == resource.data.get('banned_reason', null)
      );
      allow delete: if isPlatformAdmin();
    }

    // ─── Pets ─────────────────────────────────────────────────────────────────
    match /pets/{petId} {
      allow read: if true; // Feed público
      // owner_id pode ser o uid do próprio usuário ou o id de uma organização
      // da qual ele é admin (owner_type == 'organization') — nunca de terceiros.
      allow create: if isAuth() && (
        request.resource.data.owner_id == request.auth.uid ||
        (request.resource.data.owner_type == 'organization' && (
          isClubAdmin(request.resource.data.owner_id) ||
          canEditClubPets(request.resource.data.owner_id) ||
          hasClubPermission(request.resource.data.owner_id, 'animals')
        ))
      );
      allow update: if isAuth() && (
        resource.data.owner_id == request.auth.uid ||
        (resource.data.owner_type == 'organization' && (
          isClubAdmin(resource.data.owner_id) || canEditClubPets(resource.data.owner_id) || hasClubPermission(resource.data.owner_id, 'animals')
        )) ||
        isPlatformAdmin()
      );
      allow delete: if isAuth() && (
        resource.data.owner_id == request.auth.uid ||
        (resource.data.owner_type == 'organization' && (
          isClubAdmin(resource.data.owner_id) || canEditClubPets(resource.data.owner_id) || hasClubPermission(resource.data.owner_id, 'animals')
        )) ||
        isPlatformAdmin()
      );
    }

    // ─── Radar de Pets (alerta de pet compatível) ──────────────────────────────
    // Escrita pela Cloud Function usa o Admin SDK e ignora estas regras.
    match /pet_radars/{uid} {
      allow read: if isOwner(uid) || isPlatformAdmin();
      allow create, update: if isOwner(uid) && request.resource.data.user_id == uid;
      allow delete: if isOwner(uid) || isPlatformAdmin();
    }

    // ─── Interesses de Adoção ─────────────────────────────────────────────────
    match /adoption_interests/{interestId} {
      allow read: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        // Dono do pet (ou equipe do clube dono) pode ver todos os interesses
        canManagePet(get(/databases/$(database)/documents/pets/$(resource.data.pet_id)).data) ||
        isPlatformAdmin()
      );
      allow create: if isAuth() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuth() && (
        canManagePet(get(/databases/$(database)/documents/pets/$(resource.data.pet_id)).data) ||
        isPlatformAdmin()
      );
      allow delete: if isPlatformAdmin();
    }

    // ─── Avaliações pós-adoção ──────────────────────────────────────────────────
    match /adoption_ratings/{ratingId} {
      allow read: if true; // Reputação pública do adotante/doador
      allow create: if isAuth() && request.resource.data.rater_uid == request.auth.uid
        && request.resource.data.rated_uid != request.auth.uid;
      allow update, delete: if isPlatformAdmin();
    }

    // ─── Chat: Conversas ──────────────────────────────────────────────────────
    match /conversations/{conversationId} {
      allow read: if isAuth() && request.auth.uid in resource.data.member_ids;
      allow create: if isAuth() && request.auth.uid in request.resource.data.member_ids;
      allow update: if isAuth() && request.auth.uid in resource.data.member_ids;
      allow delete: if isPlatformAdmin();

      match /messages/{messageId} {
        allow read: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.member_ids;
        allow create: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.member_ids;
        allow update: if isAuth() && resource.data.sender_id == request.auth.uid;
        allow delete: if isPlatformAdmin();
      }
    }

    // ─── Notificações ─────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.user_id) || isPlatformAdmin();
      allow create: if isAuth();
      allow update: if isOwner(resource.data.user_id);
      allow delete: if isOwner(resource.data.user_id) || isPlatformAdmin();
    }

    // ─── Denúncias de Maus-Tratos ─────────────────────────────────────────────
    match /abuse_reports/{reportId} {
      allow read: if isOwner(resource.data.reporter_uid) || isPlatformAdmin();
      allow create: if isAuth() && request.resource.data.reporter_uid == request.auth.uid;
      allow update: if isPlatformAdmin();
      allow delete: if isPlatformAdmin();
    }

    // ─── Auditoria ────────────────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read: if isPlatformAdmin();
      allow create: if isAuth();
      allow update, delete: if false; // Imutável
    }

    // ─── Configurações da plataforma (feature flags, doc único `global`) ───────
    match /platform_settings/{docId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    // ─── Comunidades (entidade editorial/global) ───────────────────────────────
    match /communities/{communityId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    // ─── Clubes (comunidade) ────────────────────────────────────────────────────
    match /clubs/{clubId} {
      allow read: if true; // Diretório e detalhe públicos
      allow create: if isAuth() && request.resource.data.created_by == request.auth.uid;
      // `created_by` é o proprietário (dono de todas as permissões, protegido
      // contra remoção/rebaixamento — ver domain/permissions.js) e não pode
      // ser trocado por um admin comum, só por um platform_admin.
      allow update: if isPlatformAdmin() ||
        (isClubAdmin(clubId) && request.resource.data.get('created_by', resource.data.created_by) == resource.data.created_by) ||
        (isClubMember(clubId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['member_count', 'updated_at']));
      allow delete: if isClubAdmin(clubId) || isPlatformAdmin();
    }

    match /club_members/{memberId} {
      allow read: if isAuth();
      // Autoingresso (código de convite / aceitar convite) só pode criar a
      // própria associação como membro comum, sem `permissions` — impede que
      // o usuário se autopromova a admin ou se autoconceda permissões
      // granulares (animals/finance/donations/feed/team) direto pelo SDK.
      // Exceção: o próprio criador do clube (clubs.created_by) pode
      // autocriar sua associação de admin — é exatamente o passo 2 do fluxo
      // de criação de clube (createClub), sequencial e sem outro admin ainda
      // para fazer essa criação por ele. Segue sem `permissions`.
      // Qualquer outro papel/permissão só um admin existente pode conceder.
      allow create: if isAuth() && (
        (request.resource.data.user_id == request.auth.uid &&
          request.resource.data.get('role', 'member') == 'member' &&
          !('permissions' in request.resource.data)) ||
        (request.resource.data.user_id == request.auth.uid &&
          request.resource.data.get('role', '') == 'admin' &&
          !('permissions' in request.resource.data) &&
          isClubOwnerUid(request.resource.data.club_id, request.auth.uid)) ||
        isClubAdmin(request.resource.data.club_id) ||
        isPlatformAdmin()
      );
      // Proprietário é protegido: nem outro admin pode alterar seu papel/
      // permissões, nem removê-lo — só ele mesmo (saindo do clube) ou um
      // platform_admin.
      allow update: if isPlatformAdmin() ||
        (isClubAdmin(resource.data.club_id) && !isClubOwnerUid(resource.data.club_id, resource.data.user_id));
      allow delete: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        (isClubAdmin(resource.data.club_id) && !isClubOwnerUid(resource.data.club_id, resource.data.user_id)) ||
        isPlatformAdmin()
      );
    }

    match /club_join_requests/{requestId} {
      allow read: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        isClubAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
      allow create: if isAuth() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isClubAdmin(resource.data.club_id) || isPlatformAdmin();
    }

    match /club_member_invites/{inviteId} {
      allow read: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        isClubAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
      allow create: if isAuth() && isClubAdmin(request.resource.data.club_id) && request.resource.data.invited_by == request.auth.uid;
      allow update: if isAuth() && resource.data.user_id == request.auth.uid;
      allow delete: if isClubAdmin(resource.data.club_id) || isPlatformAdmin();
    }

    match /club_events/{eventId} {
      allow read: if isAuth() && (
        (resource.data.visibility == 'public' && isClubMember(resource.data.club_id)) ||
        hasEventInvite(eventId) ||
        isClubAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
      allow create: if isAuth() && isClubMember(request.resource.data.club_id) && request.resource.data.created_by == request.auth.uid;
      allow update, delete: if isAuth() && (
        resource.data.created_by == request.auth.uid ||
        isClubAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );

      match /dates/{dateId} {
        allow read: if isClubMember(eventClubId(eventId)) || hasEventInvite(eventId) || isPlatformAdmin();
        allow write: if isClubMember(eventClubId(eventId)) || isPlatformAdmin();
      }
      match /date_rsvps/{rsvpId} {
        allow read: if isClubMember(eventClubId(eventId)) || hasEventInvite(eventId) || isPlatformAdmin();
        allow write: if isClubMember(eventClubId(eventId)) || hasEventInvite(eventId) || isPlatformAdmin();
      }
      match /messages/{messageId} {
        allow read: if isClubMember(eventClubId(eventId)) || hasEventInvite(eventId) || isPlatformAdmin();
        allow create: if isAuth() && (isClubMember(eventClubId(eventId)) || hasEventInvite(eventId))
          && request.resource.data.sender_id == request.auth.uid;
        allow update: if isAuth() && resource.data.sender_id == request.auth.uid;
        allow delete: if isAuth() && (
          resource.data.sender_id == request.auth.uid ||
          isClubAdmin(eventClubId(eventId)) ||
          isPlatformAdmin()
        );
      }
      match /participants/{participantId} {
        allow read: if isClubMember(eventClubId(eventId)) || hasEventInvite(eventId) || isPlatformAdmin();
        allow write: if isClubMember(eventClubId(eventId)) || hasEventInvite(eventId) || isPlatformAdmin();
      }
    }

    // Legado: RSVP de evento em coleção de nível superior (mantido por compatibilidade).
    match /club_event_rsvps/{rsvpId} {
      allow read: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        isClubAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
      allow create, update: if isAuth() && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        isClubAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
    }

    match /event_invites/{inviteId} {
      allow read: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        resource.data.invited_by == request.auth.uid ||
        isClubAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
      allow create: if isAuth() && (
        request.resource.data.user_id == request.auth.uid ||
        request.resource.data.invited_by == request.auth.uid
      );
      allow update: if isAuth() && resource.data.user_id == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        resource.data.invited_by == request.auth.uid ||
        isClubAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
    }

    match /club_posts/{postId} {
      allow read: if isClubMember(resource.data.club_id) || isPlatformAdmin();
      allow create: if isAuth() && isClubMember(request.resource.data.club_id) && request.resource.data.author_id == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.author_id == request.auth.uid ||
        isClubAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
    }

    // ─── Chamados de doação (campanhas) de uma organização ─────────────────────
    match /club_campaigns/{campaignId} {
      allow read: if true; // Visível publicamente (transparência de arrecadação)
      allow create: if isAuth() && (
        isClubAdmin(request.resource.data.club_id) || hasClubPermission(request.resource.data.club_id, 'donations')
      );
      // `club_id` é imutável no update — impede que quem só tem permissão
      // `donations` na organização A "mude de dono" uma campanha para a
      // organização B (o campo não está na allow-list de updateClubCampaign,
      // mas a regra precisa recusar mesmo assim para quem usa o SDK direto).
      allow update: if isAuth() && request.resource.data.club_id == resource.data.club_id && (
        isClubAdmin(resource.data.club_id) || hasClubPermission(resource.data.club_id, 'donations') || isPlatformAdmin()
      );
      allow delete: if isAuth() && (
        isClubAdmin(resource.data.club_id) || hasClubPermission(resource.data.club_id, 'donations') || isPlatformAdmin()
      );
    }

    // ─── Prestação de contas (lançamentos financeiros) de uma organização ──────
    match /club_ledger/{entryId} {
      allow read: if isAuth() && (
        isClubAdmin(resource.data.club_id) || hasClubPermission(resource.data.club_id, 'finance') || isPlatformAdmin()
      );
      allow create: if isAuth() && (
        isClubAdmin(request.resource.data.club_id) || hasClubPermission(request.resource.data.club_id, 'finance')
      );
      // `club_id` imutável no update — mesma razão do club_campaigns acima.
      allow update: if isAuth() && request.resource.data.club_id == resource.data.club_id && (
        isClubAdmin(resource.data.club_id) || hasClubPermission(resource.data.club_id, 'finance') || isPlatformAdmin()
      );
      allow delete: if isAuth() && (
        isClubAdmin(resource.data.club_id) || hasClubPermission(resource.data.club_id, 'finance') || isPlatformAdmin()
      );
    }

    match /club_forum_threads/{threadId} {
      allow read: if isClubMember(resource.data.club_id) || isPlatformAdmin();
      allow create: if isAuth() && isClubMember(request.resource.data.club_id) && request.resource.data.author_id == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.author_id == request.auth.uid ||
        isClubAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
      allow delete: if isAuth() && (
        resource.data.author_id == request.auth.uid ||
        isClubAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );

      match /comments/{commentId} {
        allow read: if isClubMember(resource.data.club_id) || isPlatformAdmin();
        allow create: if isAuth() && isClubMember(request.resource.data.club_id) && request.resource.data.author_id == request.auth.uid;
        allow update: if isAuth() && resource.data.author_id == request.auth.uid;
        allow delete: if isAuth() && (
          resource.data.author_id == request.auth.uid ||
          isClubAdmin(resource.data.club_id) ||
          isPlatformAdmin()
        );
      }
      match /poll_votes/{voteUid} {
        allow read: if isClubMember(resource.data.club_id) || isPlatformAdmin();
        allow create, update: if isAuth() && voteUid == request.auth.uid && isClubMember(request.resource.data.club_id);
        allow delete: if isAuth() && voteUid == request.auth.uid;
      }
    }

    // =========================================================================
    // COMUNIDADES E FÓRUNS
    // =========================================================================
    
    match /communities/{communityId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && (isPlatformAdmin() || request.auth.uid == resource.data.owner_id);
    }
    
    match /community_members/{memberId} {
      allow read: if true;
      allow create, update, delete: if isAuth();
    }
    
    match /community_posts/{postId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid == resource.data.author_id;
      allow delete: if isAuth() && (isPlatformAdmin() || request.auth.uid == resource.data.author_id);
    }
    
    match /community_post_likes/{likeId} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    match /community_post_comments/{commentId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && (isPlatformAdmin() || request.auth.uid == resource.data.author_id);
    }
    
    match /community_events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAuth();
    }
    
    match /community_forum_threads/{threadId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && (isPlatformAdmin() || request.auth.uid == resource.data.author_id);
    }
    
    match /community_forum_messages/{messageId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && (isPlatformAdmin() || request.auth.uid == resource.data.author_id);
    }
  }
}
