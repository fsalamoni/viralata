rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() { return request.auth != null; }
    function isOwner(uid) { return isAuthed() && request.auth.uid == uid; }
    function isPlatformAdmin() {
      return isAuthed()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'platform_admin';
    }
    function isPlatformOwnerEmail() {
      return isAuthed() && request.auth.token.email == 'fsalamoni@gmail.com';
    }
    function isTournamentAdmin(tid) {
      return isAuthed()
        && exists(/databases/$(database)/documents/tournament_admins/$(tid + '_' + request.auth.uid));
    }
    function isClubMember(clubId) {
      return isAuthed()
        && exists(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid));
    }
    function isClubAdmin(clubId) {
      return isAuthed()
        && exists(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid))
        && get(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid)).data.role == 'admin';
    }
    function isClubCreator(clubId) {
      return isAuthed()
        && exists(/databases/$(database)/documents/clubs/$(clubId))
        && get(/databases/$(database)/documents/clubs/$(clubId)).data.created_by == request.auth.uid;
    }
    function isPlayerARegistrationEmailOwner() {
      return isAuthed()
        && request.auth.token.email is string
        && resource.data.player_a_email_lc == request.auth.token.email.lower()
        && request.resource.data.player_a_email_lc == request.auth.token.email.lower()
        && request.resource.data.player_a_user_id == request.auth.uid;
    }
    function isPlayerBRegistrationEmailOwner() {
      return isAuthed()
        && request.auth.token.email is string
        && resource.data.player_b_email_lc == request.auth.token.email.lower()
        && request.resource.data.player_b_email_lc == request.auth.token.email.lower()
        && request.resource.data.player_b_user_id == request.auth.uid;
    }
    function isRegistrationEmailOwnerUpdate() {
      return (isPlayerARegistrationEmailOwner()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'user_id',
            'player_a_user_id',
            'player_a_name',
            'player_a_email',
            'player_a_email_lc',
            'player_a_level',
            'player_a_competition_gender',
            'player_a_photo',
            'player_a_provisional',
            'is_provisional',
            'label',
            'claimed_at',
            'updated_at',
          ]))
        || (isPlayerBRegistrationEmailOwner()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'player_b_user_id',
            'player_b_name',
            'player_b_email',
            'player_b_email_lc',
            'player_b_level',
            'player_b_competition_gender',
            'player_b_photo',
            'player_b_provisional',
            'is_provisional',
            'label',
            'claimed_at',
            'updated_at',
          ]));
    }

    // ---- Users -----------------------------------------------------------
    match /users/{userId} {
      allow read: if isOwner(userId) || isPlatformAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isPlatformAdmin();
    }

    // ---- Tournaments -----------------------------------------------------
    match /tournaments/{tid} {
      // Leitura pública para visão de espectador (/p/:id).
      allow read: if true;
      allow create: if isAuthed() && request.resource.data.creator_uid == request.auth.uid;
      allow update: if isPlatformAdmin() || isTournamentAdmin(tid)
        || (isAuthed() && resource.data.creator_uid == request.auth.uid);
      allow delete: if isPlatformAdmin()
        || (isAuthed() && resource.data.creator_uid == request.auth.uid);
    }

    match /tournament_admins/{docId} {
      allow read: if isAuthed();
      // Owner cria o registro inicial dele próprio durante createTournament.
      allow create: if isAuthed()
        && (request.resource.data.user_id == request.auth.uid
            || isTournamentAdmin(request.resource.data.tournament_id)
            || isPlatformAdmin());
      allow update, delete: if isPlatformAdmin()
        || isTournamentAdmin(resource.data.tournament_id);
    }

    match /tournament_modalities/{mid} {
      allow read: if true;
      allow create, update, delete: if isPlatformAdmin()
        || isTournamentAdmin(request.resource.data.tournament_id)
        || isTournamentAdmin(resource.data.tournament_id);
    }

    match /tournament_registrations/{rid} {
      // Inscritos são públicos para o quadro do torneio.
      allow read: if true;
      // Próprio jogador inscreve-se, OU admin do torneio inscreve.
      allow create: if isAuthed()
        && (request.resource.data.created_by == request.auth.uid
            || isTournamentAdmin(request.resource.data.tournament_id)
            || isPlatformAdmin());
      allow update: if isPlatformAdmin()
        || isTournamentAdmin(resource.data.tournament_id)
        || (isAuthed() && resource.data.created_by == request.auth.uid)
        || isRegistrationEmailOwnerUpdate();
      allow delete: if isPlatformAdmin() || isTournamentAdmin(resource.data.tournament_id);
    }

    match /tournament_matches/{mid} {
      allow read: if true;
      allow create, update, delete: if isPlatformAdmin()
        || isTournamentAdmin(request.resource.data.tournament_id)
        || isTournamentAdmin(resource.data.tournament_id);
    }

    match /tournament_groups/{gid} {
      allow read: if true;
      allow create, update, delete: if isPlatformAdmin()
        || isTournamentAdmin(request.resource.data.tournament_id)
        || isTournamentAdmin(resource.data.tournament_id);
    }

    match /tournament_rankings/{rid} {
      allow read: if true;
      allow write: if isPlatformAdmin()
        || isTournamentAdmin(request.resource.data.tournament_id)
        || isTournamentAdmin(resource.data.tournament_id);
    }

    match /tournament_courts/{cid} {
      allow read: if true;
      allow create, update, delete: if isPlatformAdmin()
        || isTournamentAdmin(request.resource.data.tournament_id)
        || isTournamentAdmin(resource.data.tournament_id);
    }

    // ---- Notifications ---------------------------------------------------
    match /notifications/{nid} {
      allow read, update: if isAuthed() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthed();
      allow delete: if isPlatformAdmin();
    }

    // ---- Audit logs (read by platform admin only) ------------------------
    match /audit_logs/{lid} {
      allow read: if isPlatformAdmin();
      allow create: if isAuthed();
      allow update, delete: if false;
    }

    // ---- Athlete directory (public projection of users) ------------------
    // Documento público controlado: o cliente só grava aqui os campos que o
    // próprio atleta autorizou. Dados privados nunca chegam a esta coleção.
    match /athlete_profiles/{uid} {
      allow read: if isAuthed();
      allow create, update: if isOwner(uid);
      allow delete: if isOwner(uid) || isPlatformAdmin();
    }

    // ---- Clubs -----------------------------------------------------------
    match /clubs/{clubId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.resource.data.created_by == request.auth.uid;
      // Admins editam tudo; qualquer membro pode atualizar apenas o contador
      // cosmético de membros (entrar/sair do clube).
      allow update: if isClubAdmin(clubId) || isPlatformAdmin()
        || (isAuthed()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['member_count', 'updated_at']));
      allow delete: if isPlatformAdmin()
        || (isAuthed() && resource.data.created_by == request.auth.uid);
    }

    match /club_members/{docId} {
      allow read: if isAuthed();
      // Auto-ingresso como membro, criador registrando-se como admin, ou um
      // admin adicionando alguém.
      allow create: if isAuthed() && (
        (request.resource.data.user_id == request.auth.uid
          && (request.resource.data.role == 'member' || isClubCreator(request.resource.data.club_id)))
        || isClubAdmin(request.resource.data.club_id)
        || isPlatformAdmin()
      );
      allow update: if isClubAdmin(resource.data.club_id) || isPlatformAdmin();
      // Admin remove membros; qualquer um remove a própria associação (sair).
      allow delete: if isClubAdmin(resource.data.club_id) || isPlatformAdmin()
        || (isAuthed() && resource.data.user_id == request.auth.uid);
    }

    match /club_events/{eventId} {
      allow read: if isClubMember(resource.data.club_id) || isPlatformAdmin();
      allow create: if isClubMember(request.resource.data.club_id)
        && request.resource.data.created_by == request.auth.uid;
      allow update, delete: if isClubAdmin(resource.data.club_id) || isPlatformAdmin()
        || (isAuthed() && resource.data.created_by == request.auth.uid);
    }

    match /club_event_rsvps/{docId} {
      allow read: if isClubMember(resource.data.club_id) || isPlatformAdmin();
      allow create: if isAuthed()
        && request.resource.data.user_id == request.auth.uid
        && isClubMember(request.resource.data.club_id);
      allow update: if isAuthed() && resource.data.user_id == request.auth.uid;
      allow delete: if (isAuthed() && resource.data.user_id == request.auth.uid)
        || isClubAdmin(resource.data.club_id) || isPlatformAdmin();
    }

    match /club_posts/{postId} {
      allow read: if isClubMember(resource.data.club_id) || isPlatformAdmin();
      allow create: if isClubMember(request.resource.data.club_id)
        && request.resource.data.author_id == request.auth.uid;
      allow update: if isAuthed() && resource.data.author_id == request.auth.uid;
      allow delete: if (isAuthed() && resource.data.author_id == request.auth.uid)
        || isClubAdmin(resource.data.club_id) || isPlatformAdmin();
    }
  }
}
