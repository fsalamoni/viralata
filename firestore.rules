rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() { return request.auth != null; }
    function isOwner(uid) { return isAuthed() && request.auth.uid == uid; }
    function isPlatformAdmin() {
      return isAuthed()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'platform_admin';
    }
    function isPlatformOwnerEmail() {
      return isAuthed() && request.auth.token.email == 'fsalamoni@gmail.com';
    }
    function isTournamentAdmin(tid) {
      return isAuthed()
        && exists(/databases/$(database)/documents/tournament_admins/$(tid + '_' + request.auth.uid));
    }
    function isClubMember(clubId) {
      return isAuthed()
        && exists(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid));
    }
    function isClubAdmin(clubId) {
      return isAuthed()
        && exists(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid))
        && get(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid)).data.role == 'admin';
    }
    function isClubCreator(clubId) {
      return isAuthed()
        && exists(/databases/$(database)/documents/clubs/$(clubId))
        && get(/databases/$(database)/documents/clubs/$(clubId)).data.created_by == request.auth.uid;
    }
    // Dados/relações de um evento (para validar subcoleções pelo documento-pai).
    function eventData(eventId) {
      return get(/databases/$(database)/documents/club_events/$(eventId)).data;
    }
    function eventClubId(eventId) {
      return eventData(eventId).club_id;
    }
    // Eventos antigos sem o campo `visibility` são tratados como públicos.
    function eventIsPublic(eventId) {
      return eventData(eventId).get('visibility', 'public') != 'private';
    }
    // Convidado/participante do evento (doc em event_invites com id determinístico).
    function isEventInvitee(eventId) {
      return isAuthed()
        && exists(/databases/$(database)/documents/event_invites/$(eventId + '_' + request.auth.uid));
    }
    // Quem pode ver/usar o evento: admin da plataforma, criador, admin do clube,
    // convidado/participante, ou — se público — qualquer membro do clube.
    function isEventParticipant(eventId) {
      return isAuthed()
        && exists(/databases/$(database)/documents/club_events/$(eventId))
        && (isPlatformAdmin()
            || eventData(eventId).created_by == request.auth.uid
            || isClubAdmin(eventClubId(eventId))
            || isEventInvitee(eventId)
            || (eventIsPublic(eventId) && isClubMember(eventClubId(eventId))));
    }
    function isEventClubMember(eventId) {
      return isEventParticipant(eventId);
    }
    function isEventClubModerator(eventId) {
      return isAuthed()
        && exists(/databases/$(database)/documents/club_events/$(eventId))
        && (isClubAdmin(eventClubId(eventId)) || isPlatformAdmin()
            || eventData(eventId).created_by == request.auth.uid);
    }
    // Membro de uma conversa (validação pelo documento-pai para as mensagens).
    function isConversationMember(cid) {
      return isAuthed()
        && exists(/databases/$(database)/documents/conversations/$(cid))
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(cid)).data.member_ids;
    }
    // Clube de um tópico de fórum (para validar comentários/votos pelo pai).
    function forumThreadClubId(tid) {
      return get(/databases/$(database)/documents/club_forum_threads/$(tid)).data.club_id;
    }
    function isForumThreadMember(tid) {
      return isAuthed()
        && exists(/databases/$(database)/documents/club_forum_threads/$(tid))
        && isClubMember(forumThreadClubId(tid));
    }
    function isForumThreadModerator(tid) {
      return isAuthed()
        && exists(/databases/$(database)/documents/club_forum_threads/$(tid))
        && (isClubAdmin(forumThreadClubId(tid)) || isPlatformAdmin());
    }
    function isPlayerARegistrationEmailOwner() {
      return isAuthed()
        && request.auth.token.email is string
        && resource.data.player_a_email_lc == request.auth.token.email.lower()
        && request.resource.data.player_a_email_lc == request.auth.token.email.lower()
        && request.resource.data.player_a_user_id == request.auth.uid;
    }
    function isPlayerBRegistrationEmailOwner() {
      return isAuthed()
        && request.auth.token.email is string
        && resource.data.player_b_email_lc == request.auth.token.email.lower()
        && request.resource.data.player_b_email_lc == request.auth.token.email.lower()
        && request.resource.data.player_b_user_id == request.auth.uid;
    }
    function isRegistrationEmailOwnerUpdate() {
      return (isPlayerARegistrationEmailOwner()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'user_id',
            'player_a_user_id',
            'player_a_name',
            'player_a_email',
            'player_a_email_lc',
            'player_a_level',
            'player_a_competition_gender',
            'player_a_photo',
            'player_a_provisional',
            'is_provisional',
            'label',
            'claimed_at',
            'updated_at',
          ]))
        || (isPlayerBRegistrationEmailOwner()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'player_b_user_id',
            'player_b_name',
            'player_b_email',
            'player_b_email_lc',
            'player_b_level',
            'player_b_competition_gender',
            'player_b_photo',
            'player_b_provisional',
            'is_provisional',
            'label',
            'claimed_at',
            'updated_at',
          ]));
    }

    // ---- Users -----------------------------------------------------------
    match /users/{userId} {
      allow read: if isOwner(userId) || isPlatformAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isPlatformAdmin();
    }

    // ---- Tournaments -----------------------------------------------------
    match /tournaments/{tid} {
      // Leitura pública para visão de espectador (/p/:id).
      allow read: if true;
      allow create: if isAuthed() && request.resource.data.creator_uid == request.auth.uid;
      allow update: if isPlatformAdmin() || isTournamentAdmin(tid)
        || (isAuthed() && resource.data.creator_uid == request.auth.uid);
      allow delete: if isPlatformAdmin()
        || (isAuthed() && resource.data.creator_uid == request.auth.uid);
    }

    match /tournament_admins/{docId} {
      allow read: if isAuthed();
      // Owner cria o registro inicial dele próprio durante createTournament.
      allow create: if isAuthed()
        && (request.resource.data.user_id == request.auth.uid
            || isTournamentAdmin(request.resource.data.tournament_id)
            || isPlatformAdmin());
      allow update, delete: if isPlatformAdmin()
        || isTournamentAdmin(resource.data.tournament_id);
    }

    match /tournament_modalities/{mid} {
      allow read: if true;
      allow create, update, delete: if isPlatformAdmin()
        || isTournamentAdmin(request.resource.data.tournament_id)
        || isTournamentAdmin(resource.data.tournament_id);
    }

    match /tournament_registrations/{rid} {
      // Inscritos são públicos para o quadro do torneio.
      allow read: if true;
      // Próprio jogador inscreve-se, OU admin do torneio inscreve.
      allow create: if isAuthed()
        && (request.resource.data.created_by == request.auth.uid
            || isTournamentAdmin(request.resource.data.tournament_id)
            || isPlatformAdmin());
      allow update: if isPlatformAdmin()
        || isTournamentAdmin(resource.data.tournament_id)
        || (isAuthed() && resource.data.created_by == request.auth.uid)
        || isRegistrationEmailOwnerUpdate();
      allow delete: if isPlatformAdmin() || isTournamentAdmin(resource.data.tournament_id);
    }

    match /tournament_matches/{mid} {
      allow read: if true;
      allow create, update, delete: if isPlatformAdmin()
        || isTournamentAdmin(request.resource.data.tournament_id)
        || isTournamentAdmin(resource.data.tournament_id);
    }

    match /tournament_groups/{gid} {
      allow read: if true;
      allow create, update, delete: if isPlatformAdmin()
        || isTournamentAdmin(request.resource.data.tournament_id)
        || isTournamentAdmin(resource.data.tournament_id);
    }

    match /tournament_rankings/{rid} {
      allow read: if true;
      allow write: if isPlatformAdmin()
        || isTournamentAdmin(request.resource.data.tournament_id)
        || isTournamentAdmin(resource.data.tournament_id);
    }

    match /tournament_courts/{cid} {
      allow read: if true;
      allow create, update, delete: if isPlatformAdmin()
        || isTournamentAdmin(request.resource.data.tournament_id)
        || isTournamentAdmin(resource.data.tournament_id);
    }

    // ---- Notifications ---------------------------------------------------
    match /notifications/{nid} {
      allow read, update: if isAuthed() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthed();
      allow delete: if isPlatformAdmin();
    }

    // ---- Audit logs (read by platform admin only) ------------------------
    match /audit_logs/{lid} {
      allow read: if isPlatformAdmin();
      allow create: if isAuthed();
      allow update, delete: if false;
    }

    // ---- Athlete directory (public projection of users) ------------------
    // Documento público controlado: o cliente só grava aqui os campos que o
    // próprio atleta autorizou. Dados privados nunca chegam a esta coleção.
    match /athlete_profiles/{uid} {
      allow read: if isAuthed();
      allow create, update: if isOwner(uid);
      allow delete: if isOwner(uid) || isPlatformAdmin();
    }

    // ---- Clubs -----------------------------------------------------------
    match /clubs/{clubId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.resource.data.created_by == request.auth.uid;
      // Admins editam tudo; qualquer membro pode atualizar apenas o contador
      // cosmético de membros (entrar/sair do clube).
      allow update: if isClubAdmin(clubId) || isPlatformAdmin()
        || (isAuthed()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['member_count', 'updated_at']));
      allow delete: if isPlatformAdmin()
        || (isAuthed() && resource.data.created_by == request.auth.uid);
    }

    match /club_members/{docId} {
      allow read: if isAuthed();
      // Auto-ingresso como membro, criador registrando-se como admin, ou um
      // admin adicionando alguém.
      allow create: if isAuthed() && (
        (request.resource.data.user_id == request.auth.uid
          && (request.resource.data.role == 'member' || isClubCreator(request.resource.data.club_id)))
        || isClubAdmin(request.resource.data.club_id)
        || isPlatformAdmin()
      );
      allow update: if isClubAdmin(resource.data.club_id) || isPlatformAdmin();
      // Admin remove membros; qualquer um remove a própria associação (sair).
      allow delete: if isClubAdmin(resource.data.club_id) || isPlatformAdmin()
        || (isAuthed() && resource.data.user_id == request.auth.uid);
    }

    match /club_events/{eventId} {
      // Público (ou legado sem o campo): qualquer membro do clube lê.
      // Privado: apenas criador, admin do clube, plataforma ou convidado.
      allow read: if isPlatformAdmin()
        || (isAuthed() && resource.data.created_by == request.auth.uid)
        || isClubAdmin(resource.data.club_id)
        || isEventInvitee(eventId)
        || (resource.data.get('visibility', 'public') != 'private' && isClubMember(resource.data.club_id));
      allow create: if isClubMember(request.resource.data.club_id)
        && request.resource.data.created_by == request.auth.uid;
      // Criador, admin e participantes (incluindo convidados) editam livremente.
      allow update: if isPlatformAdmin()
        || (isAuthed() && resource.data.created_by == request.auth.uid)
        || isClubAdmin(resource.data.club_id)
        || isEventInvitee(eventId)
        || (resource.data.get('visibility', 'public') != 'private' && isClubMember(resource.data.club_id));
      allow delete: if isClubAdmin(resource.data.club_id) || isPlatformAdmin()
        || (isAuthed() && resource.data.created_by == request.auth.uid);

      // Datas do evento (data, local, horário) — editáveis pelos participantes.
      match /dates/{dateId} {
        allow read: if isEventClubMember(eventId) || isPlatformAdmin();
        allow create, update, delete: if isEventClubMember(eventId) || isPlatformAdmin();
      }

      // Resposta por data (vou/talvez/não vou). Cada um grava a própria resposta.
      match /date_rsvps/{docId} {
        allow read: if isEventClubMember(eventId) || isPlatformAdmin();
        allow create, update: if isAuthed()
          && request.resource.data.user_id == request.auth.uid
          && isEventClubMember(eventId);
        allow delete: if (isAuthed() && resource.data.user_id == request.auth.uid)
          || isEventClubModerator(eventId);
      }

      // Chat cronológico do evento.
      match /messages/{messageId} {
        allow read: if isEventClubMember(eventId) || isPlatformAdmin();
        allow create: if isEventClubMember(eventId)
          && request.resource.data.sender_id == request.auth.uid;
        allow update, delete: if (isAuthed() && resource.data.sender_id == request.auth.uid)
          || isEventClubModerator(eventId);
      }

      // Participantes do dia de jogo (edição livre pelos participantes).
      match /participants/{participantId} {
        allow read: if isEventClubMember(eventId) || isPlatformAdmin();
        allow create, update, delete: if isEventClubMember(eventId) || isPlatformAdmin();
      }

      // Jogos organizados/sorteados (edição livre pelos participantes).
      match /games/{gameId} {
        allow read: if isEventClubMember(eventId) || isPlatformAdmin();
        allow create, update, delete: if isEventClubMember(eventId) || isPlatformAdmin();
      }
    }

    // ---- Convites/participações em eventos (coleção de nível superior) -----
    // Id determinístico `${eventId}_${uid}`. Permite ao usuário listar seus
    // próprios convites (início) e aos participantes verem a lista do evento.
    match /event_invites/{docId} {
      // `resource == null` cobre o `get` de um convite ainda inexistente (ex.:
      // verificação antes de criar) — sem isso o acesso a resource.data falha.
      allow read: if isAuthed() && (
        resource == null
        || resource.data.user_id == request.auth.uid
        || isEventParticipant(resource.data.event_id)
      );
      // Auto-resposta a evento público, aceite de convite, ou um participante
      // convidando outro atleta.
      allow create: if isAuthed() && (
        (request.resource.data.user_id == request.auth.uid
          && (eventIsPublic(request.resource.data.event_id) || isEventInvitee(request.resource.data.event_id)))
        || isEventParticipant(request.resource.data.event_id)
      );
      allow update: if isAuthed()
        && (resource.data.user_id == request.auth.uid || isEventParticipant(resource.data.event_id));
      allow delete: if isAuthed()
        && (resource.data.user_id == request.auth.uid
            || isEventClubModerator(resource.data.event_id)
            || isEventParticipant(resource.data.event_id));
    }

    match /club_event_rsvps/{docId} {
      allow read: if isClubMember(resource.data.club_id) || isPlatformAdmin();
      allow create: if isAuthed()
        && request.resource.data.user_id == request.auth.uid
        && isClubMember(request.resource.data.club_id);
      allow update: if isAuthed() && resource.data.user_id == request.auth.uid;
      allow delete: if (isAuthed() && resource.data.user_id == request.auth.uid)
        || isClubAdmin(resource.data.club_id) || isPlatformAdmin();
    }

    match /club_posts/{postId} {
      allow read: if isClubMember(resource.data.club_id) || isPlatformAdmin();
      allow create: if isClubMember(request.resource.data.club_id)
        && request.resource.data.author_id == request.auth.uid;
      allow update: if isAuthed() && resource.data.author_id == request.auth.uid;
      allow delete: if (isAuthed() && resource.data.author_id == request.auth.uid)
        || isClubAdmin(resource.data.club_id) || isPlatformAdmin();
    }

    // ---- Club forum: threads, comments and poll votes --------------------
    // Comentários e votos ficam em subcoleções do tópico, validados pelo clube
    // do tópico-pai. Isso evita índices compostos e mantém o acesso restrito
    // aos membros do clube.
    match /club_forum_threads/{threadId} {
      allow read: if isClubMember(resource.data.club_id) || isPlatformAdmin();
      allow create: if isClubMember(request.resource.data.club_id)
        && request.resource.data.author_id == request.auth.uid;
      // Autor edita o próprio tópico; admins moderam; qualquer membro pode
      // apenas atualizar os campos cosméticos ao comentar (contador/atividade).
      allow update: if isClubAdmin(resource.data.club_id) || isPlatformAdmin()
        || (isAuthed() && resource.data.author_id == request.auth.uid)
        || (isClubMember(resource.data.club_id)
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['comment_count', 'last_activity_ms', 'participant_ids', 'updated_at']));
      allow delete: if isClubAdmin(resource.data.club_id) || isPlatformAdmin()
        || (isAuthed() && resource.data.author_id == request.auth.uid);

      match /comments/{commentId} {
        allow read: if isForumThreadMember(threadId) || isPlatformAdmin();
        allow create: if isForumThreadMember(threadId)
          && request.resource.data.author_id == request.auth.uid;
        allow update: if isAuthed() && resource.data.author_id == request.auth.uid;
        allow delete: if (isAuthed() && resource.data.author_id == request.auth.uid)
          || isForumThreadModerator(threadId);
      }

      match /poll_votes/{voterId} {
        allow read: if isForumThreadMember(threadId) || isPlatformAdmin();
        // O id do documento é o uid do votante: cada um só grava o próprio voto.
        allow create, update: if isAuthed()
          && voterId == request.auth.uid
          && isForumThreadMember(threadId);
        allow delete: if isAuthed() && voterId == request.auth.uid;
      }
    }

    // ---- Chat: conversations and messages --------------------------------
    // Mensagens ficam na subcoleção `conversations/{id}/messages`: o acesso é
    // validado pelo documento-pai (membros da conversa), sem denormalizar
    // membros em cada mensagem nem exigir índices compostos.
    match /conversations/{conversationId} {
      // get permite ler um documento inexistente (resource == null) para que o
      // cliente verifique/abra conversas diretas de id determinístico.
      allow get: if isAuthed()
        && (resource == null || request.auth.uid in resource.data.member_ids);
      allow list: if isAuthed() && request.auth.uid in resource.data.member_ids;
      allow create: if isAuthed()
        && request.auth.uid in request.resource.data.member_ids
        && request.resource.data.created_by == request.auth.uid;
      // Qualquer participante pode atualizar (resumo, renomear, sair, ocultar);
      // sair/excluir operam sobre o documento atual, onde ainda é membro.
      allow update, delete: if isAuthed() && request.auth.uid in resource.data.member_ids;

      match /messages/{messageId} {
        allow read: if isConversationMember(conversationId);
        allow create: if isConversationMember(conversationId)
          && request.resource.data.sender_id == request.auth.uid;
        allow update, delete: if isAuthed() && resource.data.sender_id == request.auth.uid;
      }
    }
  }
}
