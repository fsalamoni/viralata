rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function isPlatformAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'platform_admin';
    }
    function isClubMember(clubId) {
      return isAuth() && exists(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid));
    }
    // === Comunidade helpers ===
    // Mesma estrutura do clube mas usando `community_members/<communityId>_<uid>`.
    // Fallback por owner_id para comunidades LEGADAS cujo creator não foi
    // adicionado como member (mesma correção aplicada em
    // src/modules/communities/domain/permissions.js no PR #30).
    function isCommunityMember(communityId) {
      return isAuth() && exists(/databases/$(database)/documents/community_members/$(communityId + '_' + request.auth.uid));
    }
    function isCommunityAdmin(communityId) {
      return isCommunityMember(communityId)
        && get(/databases/$(database)/documents/community_members/$(communityId + '_' + request.auth.uid)).data.role == 'admin';
    }
    function canManageCommunity(community) {
      return isAuth() && (
        // Plataforma sempre pode
        isPlatformAdmin()
        // Dono (mesmo sem doc de member)
        || (community.owner_id != null && community.owner_id == request.auth.uid)
        // Admin da comunidade via membership
        || isCommunityAdmin(community.id)
      );
    }
    function isClubAdmin(clubId) {
      return isAuth() && exists(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid))
        && get(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid)).data.role == 'admin';
    }
    // O criador da ONG (`clubs.created_by`) tem todas as permissões de admin
    // mesmo quando o doc `club_members/{clubId_uid}` ainda não foi inserido
    // (ONG legada, race condition pós-criação, etc.). Espelha o fallback
    // client-side em `domain/permissions.js::isClubOwner`.
    function isClubOwnerOrAdmin(clubId) {
      return isAuth() && (
        isClubOwnerUid(clubId, request.auth.uid)
        || isClubAdmin(clubId)
      );
    }
    function hasEventInvite(eventId) {
      return isAuth() && exists(/databases/$(database)/documents/event_invites/$(eventId + '_' + request.auth.uid));
    }
    function eventClubId(eventId) {
      return get(/databases/$(database)/documents/club_events/$(eventId)).data.club_id;
    }
    // Permissão granular de um membro comum para editar os pets do clube
    // (admins já podem via isClubAdmin, independente desta flag).
    function canEditClubPets(clubId) {
      return isAuth() && exists(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid))
        && get(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid)).data.get('permissions', {}).get('edit_pets', false) == true;
    }
    // Permissão granular do painel de administração da organização
    // (`animals`, `finance`, `donations`, `feed`, `team` — ver
    // src/modules/organizations/domain/permissions.js). Admins já têm tudo
    // via isClubAdmin, independente desta flag.
    function hasClubPermission(clubId, key) {
      return isAuth() && exists(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid))
        && get(/databases/$(database)/documents/club_members/$(clubId + '_' + request.auth.uid)).data.get('permissions', {}).get(key, false) == true;
    }
    // Proprietário do clube (dono de todas as permissões, protegido contra
    // remoção/rebaixamento por outros admins — ver domain/permissions.js).
    function isClubOwnerUid(clubId, uid) {
      return exists(/databases/$(database)/documents/clubs/$(clubId))
        && get(/databases/$(database)/documents/clubs/$(clubId)).data.created_by == uid;
    }
    // Quem pode gerenciar um pet (dono pessoa física, ou clube dono via admin/permissão).
    function canManagePet(petData) {
      return petData.owner_id == request.auth.uid ||
        (petData.get('owner_type', '') == 'organization' && (
          isClubOwnerOrAdmin(petData.owner_id) || canEditClubPets(petData.owner_id) || hasClubPermission(petData.owner_id, 'animals')
        ));
    }
    // Dono fixo da plataforma (bootstrap do primeiro platform_admin) — espelha
    // a mesma checagem por e-mail já feita no client (FirebaseAuthContext).
    function isPlatformOwnerAuth() {
      return isAuth() && request.auth.token.email != null
        && request.auth.token.email.lower() == 'fsalamoni@gmail.com';
    }

    // ─── Fase 2: Helper para buscar o shelter_owner_club_id do pet ──────────
    // Usado pela regra da subcoleção `timeline` para checar se o usuário
    // é do abrigo dono. Retorna null se pet não tem abrigo vinculado
    // (pet individual). Lê o doc com `get` — isso custa 1 read por
    // checagem. Como o cache de rules é razoável, não é problema.
    function _petShelterClubId(petId) {
      return get(/databases/$(database)/documents/pets/$(petId)).data.get('shelter_owner_club_id', null);
    }

    // ─── Fase 1: Validação do Cadastro Único do Animal ──────────────────
    // Espelha o Zod schema `shelterAnimalProfileSchema` em
    // src/modules/shelter/domain/core/animal.js. Defense-in-depth: se o
    // client for burlado, o Firestore ainda rejeita.
    //
    // Só valida campos PRESENTES no resource. Campos opcionais não precisam
    // estar lá (backward-compat com pets legados).
    function _shelterAnimalProfileValid(newData, oldData) {
      return
        // microchip_id: 15 dígitos se presente
        (!('microchip_id' in newData) || newData.microchip_id == null ||
          (newData.microchip_id is string &&
           newData.microchip_id.size() == 15 &&
           newData.microchip_id.matches('^[0-9]{15}$'))) &&
        // asilomar_status: enum se presente
        (!('asilomar_status' in newData) ||
          newData.asilomar_status in ['healthy', 'treatable_rehabilitatable',
                                      'treatable_manageable', 'unhealthy_untreatable',
                                      'undetermined']) &&
        // intake_type: enum se presente
        (!('intake_type' in newData) || newData.intake_type == null ||
          newData.intake_type in ['rescue', 'born', 'transfer', 'surrender', 'purchase']) &&
        // rescue_date: string ISO 8601 se presente
        (!('rescue_date' in newData) || newData.rescue_date == null ||
          (newData.rescue_date is string &&
           newData.rescue_date.size() >= 10)) &&
        // deceased_at: string ISO 8601 se presente
        (!('deceased_at' in newData) || newData.deceased_at == null ||
          (newData.deceased_at is string &&
           newData.deceased_at.size() >= 10)) &&
        // shelter_owner_club_id: string não-vazia se presente
        (!('shelter_owner_club_id' in newData) || newData.shelter_owner_club_id == null ||
          (newData.shelter_owner_club_id is string &&
           newData.shelter_owner_club_id.size() > 0)) &&
        // rescue_by_uid: string se presente
        (!('rescue_by_uid' in newData) || newData.rescue_by_uid == null ||
          (newData.rescue_by_uid is string &&
           newData.rescue_by_uid.size() > 0))
    }

    // ─── Usuários ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();
      // role só pode ser 'platform_admin' na criação se for o dono fixo da
      // plataforma — evita que qualquer usuário se autopromova a admin.
      allow create: if isOwner(userId) && (
        request.resource.data.get('role', 'user') == 'user' ||
        (request.resource.data.role == 'platform_admin' && isPlatformOwnerAuth())
      );
      // O próprio usuário só edita seu perfil; role/banimento são imutáveis
      // por ele mesmo (exceto o bootstrap do dono fixo), só um platform_admin
      // pode banir/desbanir ou alterar papéis.
      allow update: if isPlatformAdmin() || (
        isOwner(userId) &&
        (request.resource.data.get('role', 'user') == resource.data.get('role', 'user') ||
          (request.resource.data.role == 'platform_admin' && isPlatformOwnerAuth())) &&
        request.resource.data.get('banned', false) == resource.data.get('banned', false) &&
        request.resource.data.get('banned_at', null) == resource.data.get('banned_at', null) &&
        request.resource.data.get('banned_reason', null) == resource.data.get('banned_reason', null)
      );
      allow delete: if isPlatformAdmin();

      // ─── Fase 4: Subcoleção `adopter_profile` (perfil completo) ──────
      // O perfil pertence ao adotante. Acesso:
      // - read: o próprio dono (uid) + platform_admin (debug/LGPD)
      // - write: o próprio dono
      //
      // Padrão: o abrigo NÃO lê o adopter_profile diretamente. Quando o
      // adotante submete uma application, o service faz um SNAPSHOT dos
      // campos relevantes para `applicant_form` (na subcoleção de adoption
      // workflow). Esse snapshot é o que o abrigo vê. Isso evita ter
      // que gerenciar consent granular por abrigo aqui.
      match /adopter_profile/{profileId} {
        allow read: if isAuth() && (isOwner(userId) || isPlatformAdmin());
        allow create: if isOwner(userId) && request.resource.data.user_uid == userId;
        allow update: if isOwner(userId) && request.resource.data.user_uid == userId;
        allow delete: if isOwner(userId) || isPlatformAdmin();
      }

<<<<<<< HEAD
      // ─── Fase 13: Subcoleção `volunteer_profile` (perfil do voluntário) ───
      // O perfil global do voluntário (skills, availability, radius, aceite
      // do termo). Doc único por uid (id fixo "main"). LGPD: apenas o
      // próprio dono lê/escreve, plataforma admin (debug) tem acesso.
      // Padrão: o abrigo NÃO lê este perfil diretamente. Quando o
      // voluntário entra na rostagem, o service faz um SNAPSHOT dos
      // campos relevantes para `clubs/{clubId}/volunteers/{uid}`. Esse
      // snapshot é o que o abrigo vê — defense-in-depth.
      match /volunteer_profile/{profileId} {
        allow read: if isAuth() && (isOwner(userId) || isPlatformAdmin());
        allow create: if isOwner(userId) && request.resource.data.get('terms_accepted_at', null) is string;
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId) || isPlatformAdmin();
=======
      // ─── Fase 19: Subcoleção `terms_acceptances` (aceites legais) ──
      // Cada aceite é IMUTÁVEL (Lei 14.063/2020 — prova legal). Não pode
      // ser editado nem deletado pelo próprio usuário — apenas lido.
      // Apenas platform_admin pode remover (via Admin SDK, fora do client).
      //
      // - read: o próprio dono (uid) + platform_admin (auditoria LGPD)
      // - create: o próprio dono, com user_uid consistente
      // - update: BLOQUEADO — aceite é prova legal
      // - delete: apenas platform_admin
      //
      // Não há índices em subcoleção simples (auto-criado pelo Firestore
      // para campos `accepted_at`, `terms_type`, `terms_version`).
      match /terms_acceptances/{acceptanceId} {
        allow read: if isAuth() && (isOwner(userId) || isPlatformAdmin());
        allow create: if isOwner(userId) && request.resource.data.user_uid == userId;
        allow update: if false;
        allow delete: if isPlatformAdmin();
>>>>>>> e862878 (feat(shelter): Fase 19 — Termos e Políticas completos (SHELTER_LEGAL_TERMS))
      }
    }

    // ─── Pets ─────────────────────────────────────────────────────────────────
    match /pets/{petId} {
      allow read: if true; // Feed público
      // owner_id pode ser o uid do próprio usuário ou o id de uma organização
      // da qual ele é admin (owner_type == 'organization') — nunca de terceiros.
      allow create: if isAuth() && (
        request.resource.data.owner_id == request.auth.uid ||
        (request.resource.data.owner_type == 'organization' && (
          isClubOwnerOrAdmin(request.resource.data.owner_id) ||
          canEditClubPets(request.resource.data.owner_id) ||
          hasClubPermission(request.resource.data.owner_id, 'animals')
        ))
      );
      allow update: if isAuth() && (
        resource.data.owner_id == request.auth.uid ||
        (resource.data.owner_type == 'organization' && (
          isClubOwnerOrAdmin(resource.data.owner_id) || canEditClubPets(resource.data.owner_id) || hasClubPermission(resource.data.owner_id, 'animals')
        )) ||
        isPlatformAdmin()
      ) && (
        // Defeito de segurança: o owner_id NÃO pode ser trocado por update,
        // mesmo pelo próprio dono. Apenas platform_admin pode reatribuir.
        // Sem isso, qualquer usuário autenticado poderia 'roubar' pets
        // de outros criando update com novo owner_id.
        request.resource.data.owner_id == resource.data.owner_id ||
        isPlatformAdmin()
      );
      allow delete: if isAuth() && (
        resource.data.owner_id == request.auth.uid ||
        (resource.data.owner_type == 'organization' && (
          isClubOwnerOrAdmin(resource.data.owner_id) || canEditClubPets(resource.data.owner_id) || hasClubPermission(resource.data.owner_id, 'animals')
        )) ||
        isPlatformAdmin()
      );

      // ─── Fase 1: Cadastro Único do Animal (perfil de abrigo) ───────────────
      // Os campos do schema `shelterAnimalProfileSchema` (resgate, microchip,
      // intake, asilomar, deceased_at) podem ser editados pelas mesmas
      // pessoas que editam o pet. A regra de update acima já permite, mas
      // adicionamos validação de formato e o princípio de não-trocar
      // `shelter_owner_club_id` sem platform_admin.
      //
      // Reforços:
      // 1. `shelter_owner_club_id` se setado, só pode ser alterado por
      //    platform_admin OU se o pet mudar de dono organizacional
      //    explicitamente (Fase 1: ainda não implementado — campo é write-once).
      // 2. `rescue_date`, `asilomar_evaluated_at`, `deceased_at` devem ser
      //    ISO 8601 (validação no service via Zod — aqui só bloqueia tipos
      //    errados).
      // 3. `microchip_id` se presente, deve ter 15 dígitos.
      // 4. `asilomar_status` se presente, deve ser um dos 5 valores válidos.
      // 5. `intake_type` se presente, deve ser um dos 5 valores válidos.
      allow update: if isAuth() && (
        resource.data.owner_id == request.auth.uid ||
        (resource.data.owner_type == 'organization' && (
          isClubOwnerOrAdmin(resource.data.owner_id) || canEditClubPets(resource.data.owner_id) || hasClubPermission(resource.data.owner_id, 'animals')
        )) ||
        isPlatformAdmin()
      ) && (
        // Não-trocar owner_id
        request.resource.data.owner_id == resource.data.owner_id ||
        isPlatformAdmin()
      ) && (
        // Validação dos campos do Cadastro Único (Fase 1)
        _shelterAnimalProfileValid(request.resource.data, resource.data) &&
        // shelter_owner_club_id é write-once: se já setado, não pode mudar
        // sem platform_admin. Se ainda não setado, qualquer um dos editores
        // acima pode setar.
        (
          !('shelter_owner_club_id' in resource.data) ||
          resource.data.shelter_owner_club_id == null ||
          request.resource.data.shelter_owner_club_id == resource.data.shelter_owner_club_id ||
          isPlatformAdmin()
        )
      );

      // ─── Fase 2: Subcoleção `timeline` (multi-tenant) ───────────────
      // Eventos de vida do animal (vacina, pesagem, consulta, etc). É
      // tenant-specific: cada evento carrega `shelter_club_id` e o
      // Firestore garante que só o abrigo correto lê/escreve.
      //
      // Regras:
      // - read: abrigo dono do pet (via `shelter_owner_club_id`) vê tudo;
      //         plataforma_admin vê tudo; público NÃO vê (são notas internas).
      // - create: abrigo com permissão `animals` no club OU dono direto do
      //           pet individual. `shelter_club_id` é obrigatório.
      // - update: abrigo dono. `shelter_club_id` é IMUTÁVEL (write-once).
      // - delete: abrigo dono (soft delete via update na verdade).
      match /timeline/{eventId} {
        allow read: if isAuth() && (
          // Platform admin sempre pode
          isPlatformAdmin() ||
          // Abrigo dono do pet (lê via get)
          (_petShelterClubId(petId) != null &&
            isClubOwnerOrAdmin(_petShelterClubId(petId))) ||
          canEditClubPets(_petShelterClubId(petId)) ||
          hasClubPermission(_petShelterClubId(petId), 'animals') ||
          // Dono direto do pet (pessoa física) também lê
          canManagePet(get(/databases/$(database)/documents/pets/$(petId)).data)
        );
        allow create: if isAuth() && (
          // shelter_club_id é obrigatório
          request.resource.data.shelter_club_id is string &&
          request.resource.data.shelter_club_id.size() > 0 &&
          // Quem pode adicionar: abrigo do pet com permissão, OU dono direto
          (canManagePet(get(/databases/$(database)/documents/pets/$(petId)).data) ||
           (request.resource.data.shelter_club_id != null &&
            (isClubOwnerOrAdmin(request.resource.data.shelter_club_id) ||
             canEditClubPets(request.resource.data.shelter_club_id) ||
             hasClubPermission(request.resource.data.shelter_club_id, 'animals'))) ||
           isPlatformAdmin())
        );
        allow update: if isAuth() && (
          // shelter_club_id é IMUTÁVEL
          request.resource.data.shelter_club_id == resource.data.shelter_club_id &&
          // Quem pode editar: abrigo do pet, OU platform admin
          (isPlatformAdmin() ||
           canManagePet(get(/databases/$(database)/documents/pets/$(petId)).data) ||
           (resource.data.shelter_club_id != null &&
            (isClubOwnerOrAdmin(resource.data.shelter_club_id) ||
             canEditClubPets(resource.data.shelter_club_id) ||
             hasClubPermission(resource.data.shelter_club_id, 'animals'))))
        );
        allow delete: if isAuth() && isPlatformAdmin();
      }

      // ─── Fase 8: Subcoleção `medical` (Prontuário Veterinário) ───
      // Multi-tenant via shelter_club_id em cada record. Defense-in-depth:
      // se o pet não pertence a nenhum abrigo, somente o owner / admin
      // vê (pets individuais não compartilham prontuário com abrigos).
      match /medical/{recordId} {
        allow read: if isAuth() && (
          isPlatformAdmin() ||
          canManagePet(get(/databases/$(database)/documents/pets/$(petId)).data) ||
          (resource.data.shelter_club_id != null &&
            (isClubOwnerOrAdmin(resource.data.shelter_club_id) ||
             canEditClubPets(resource.data.shelter_club_id) ||
             hasClubPermission(resource.data.shelter_club_id, 'animals') ||
             hasClubPermission(resource.data.shelter_club_id, 'health')))
        );
        allow create: if isAuth() && (
          isPlatformAdmin() ||
          canManagePet(get(/databases/$(database)/documents/pets/$(petId)).data) ||
          (request.resource.data.shelter_club_id != null &&
            (isClubOwnerOrAdmin(request.resource.data.shelter_club_id) ||
             canEditClubPets(request.resource.data.shelter_club_id) ||
             hasClubPermission(request.resource.data.shelter_club_id, 'animals') ||
             hasClubPermission(request.resource.data.shelter_club_id, 'health')))
        );
        allow update: if isAuth() && (
          isPlatformAdmin() ||
          canManagePet(get(/databases/$(database)/documents/pets/$(petId)).data) ||
          (resource.data.shelter_club_id != null &&
            (isClubOwnerOrAdmin(resource.data.shelter_club_id) ||
             canEditClubPets(resource.data.shelter_club_id) ||
             hasClubPermission(resource.data.shelter_club_id, 'animals') ||
             hasClubPermission(resource.data.shelter_club_id, 'health')))
        );
        allow delete: if isAuth() && isPlatformAdmin();
      }

      // ─── Fase 9: Subcoleção `medications` (Prescrição + Doses) ───
      // Multi-tenant via shelter_club_id em cada medicação. Doses ficam
      // em sub-subcoleção `doses/` (mesmas regras de leitura).
      match /medications/{medId} {
        allow read: if isAuth() && (
          isPlatformAdmin() ||
          canManagePet(get(/databases/$(database)/documents/pets/$(petId)).data) ||
          (resource.data.shelter_club_id != null &&
            (isClubOwnerOrAdmin(resource.data.shelter_club_id) ||
             canEditClubPets(resource.data.shelter_club_id) ||
             hasClubPermission(resource.data.shelter_club_id, 'animals') ||
             hasClubPermission(resource.data.shelter_club_id, 'health')))
        );
        allow create: if isAuth() && (
          isPlatformAdmin() ||
          canManagePet(get(/databases/$(database)/documents/pets/$(petId)).data) ||
          (request.resource.data.shelter_club_id != null &&
            (isClubOwnerOrAdmin(request.resource.data.shelter_club_id) ||
             canEditClubPets(request.resource.data.shelter_club_id) ||
             hasClubPermission(request.resource.data.shelter_club_id, 'animals') ||
             hasClubPermission(request.resource.data.shelter_club_id, 'health')))
        );
        allow update: if isAuth() && (
          isPlatformAdmin() ||
          canManagePet(get(/databases/$(database)/documents/pets/$(petId)).data) ||
          (resource.data.shelter_club_id != null &&
            (isClubOwnerOrAdmin(resource.data.shelter_club_id) ||
             canEditClubPets(resource.data.shelter_club_id) ||
             hasClubPermission(resource.data.shelter_club_id, 'animals') ||
             hasClubPermission(resource.data.shelter_club_id, 'health')))
        );
        allow delete: if isAuth() && isPlatformAdmin();

        // Doses: escrita idempotente por abrigo; leitura para voluntários.
        match /doses/{doseId} {
          allow read: if isAuth() && (
            isPlatformAdmin() ||
            canManagePet(get(/databases/$(database)/documents/pets/$(petId)).data) ||
            (get(/databases/$(database)/documents/pets/$(petId)/medications/$(medId)).data.shelter_club_id != null &&
              (isClubOwnerOrAdmin(get(/databases/$(database)/documents/pets/$(petId)/medications/$(medId)).data.shelter_club_id) ||
               canEditClubPets(get(/databases/$(database)/documents/pets/$(petId)/medications/$(medId)).data.shelter_club_id) ||
               hasClubPermission(get(/databases/$(database)/documents/pets/$(petId)/medications/$(medId)).data.shelter_club_id, 'animals') ||
               hasClubPermission(get(/databases/$(database)/documents/pets/$(petId)/medications/$(medId)).data.shelter_club_id, 'health')))
          );
          allow create, update: if isAuth() && (
            isPlatformAdmin() ||
            canManagePet(get(/databases/$(database)/documents/pets/$(petId)).data) ||
            (request.resource.data.shelter_club_id != null &&
              (isClubOwnerOrAdmin(request.resource.data.shelter_club_id) ||
               canEditClubPets(request.resource.data.shelter_club_id) ||
               hasClubPermission(request.resource.data.shelter_club_id, 'animals') ||
               hasClubPermission(request.resource.data.shelter_club_id, 'health')))
          );
          allow delete: if isAuth() && isPlatformAdmin();
        }
      }
    }


    // ─── Fase 10: Coleção `pet_photos` (Galeria multi-tenant) ─────────
    // Soft delete + purge 30d via Cloud Function galleryPurgeCron.
    // Multi-tenant via shelter_club_id em cada foto. A foto é do pet
    // mas pertence ao abrigo que a subiu.
    match /pet_photos/{photoId} {
      allow read: if isAuth() && (
        isPlatformAdmin() ||
        (resource.data.shelter_club_id != null &&
          (isClubOwnerOrAdmin(resource.data.shelter_club_id) ||
           canEditClubPets(resource.data.shelter_club_id) ||
           hasClubPermission(resource.data.shelter_club_id, 'animals') ||
           hasClubPermission(resource.data.shelter_club_id, 'gallery')))
      );
      allow create: if isAuth() && (
        isPlatformAdmin() ||
        (request.resource.data.shelter_club_id != null &&
          (isClubOwnerOrAdmin(request.resource.data.shelter_club_id) ||
           canEditClubPets(request.resource.data.shelter_club_id) ||
           hasClubPermission(request.resource.data.shelter_club_id, 'animals') ||
           hasClubPermission(request.resource.data.shelter_club_id, 'gallery')))
      );
      allow update: if isAuth() && (
        isPlatformAdmin() ||
        (resource.data.shelter_club_id != null &&
          (isClubOwnerOrAdmin(resource.data.shelter_club_id) ||
           canEditClubPets(resource.data.shelter_club_id) ||
           hasClubPermission(resource.data.shelter_club_id, 'animals') ||
           hasClubPermission(resource.data.shelter_club_id, 'gallery')))
      );
      // Delete físico: só Cloud Function galleryPurgeCron (admin SDK)
      // e platform_admin (debug). Soft delete é via update (deleted_at).
      allow delete: if isAuth() && isPlatformAdmin();
    }

    // ─── Radar de Pets (alerta de pet compatível) ──────────────────────────
    // Escrita pela Cloud Function usa o Admin SDK e ignora estas regras.
    match /pet_radars/{uid} {
      allow read: if isOwner(uid) || isPlatformAdmin();
      allow create, update: if isOwner(uid) && request.resource.data.user_id == uid;
      allow delete: if isOwner(uid) || isPlatformAdmin();
    }

    // ─── Interesses de Adoção ─────────────────────────────────────────────────
    match /adoption_interests/{interestId} {
      allow read: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        // Dono do pet (ou equipe do clube dono) pode ver todos os interesses
        canManagePet(get(/databases/$(database)/documents/pets/$(resource.data.pet_id)).data) ||
        isPlatformAdmin()
      );
      allow create: if isAuth() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuth() && (
        canManagePet(get(/databases/$(database)/documents/pets/$(resource.data.pet_id)).data) ||
        isPlatformAdmin()
      );
      // O próprio adotante pode remover seu interesse ("Meus Interesses").
      // O dono do pet cancela via update de status (rejected), não deletando.
      allow delete: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        isPlatformAdmin()
      );
    }

    // ─── Avaliações pós-adoção ──────────────────────────────────────────────────
    match /adoption_ratings/{ratingId} {
      allow read: if true; // Reputação pública do adotante/doador
      allow create: if isAuth() && request.resource.data.rater_uid == request.auth.uid
        && request.resource.data.rated_uid != request.auth.uid;
      allow update, delete: if isPlatformAdmin();
    }

    // ─── Chat: Conversas ──────────────────────────────────────────────────────
    match /conversations/{conversationId} {
      allow read: if isAuth() && request.auth.uid in resource.data.member_ids;
      allow create: if isAuth() && request.auth.uid in request.resource.data.member_ids;
      // Permite update para membros, mas NÃO para alterar member_ids
      // (caso contrário, um membro poderia remover outros). Apenas
      // platform_admin pode mudar a composição de membros.
      allow update: if isAuth() && request.auth.uid in resource.data.member_ids && (
        request.resource.data.member_ids == resource.data.member_ids ||
        isPlatformAdmin()
      );
      allow delete: if isPlatformAdmin();

      match /messages/{messageId} {
        allow read: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.member_ids;
        allow create: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.member_ids;
        allow update: if isAuth() && resource.data.sender_id == request.auth.uid;
        allow delete: if isPlatformAdmin();
      }
    }

    // ─── Notificações ─────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.user_id) || isPlatformAdmin();
      allow create: if isAuth();
      allow update: if isOwner(resource.data.user_id);
      allow delete: if isOwner(resource.data.user_id) || isPlatformAdmin();
    }

    // ─── Denúncias de Maus-Tratos ─────────────────────────────────────────────
    match /abuse_reports/{reportId} {
      allow read: if isOwner(resource.data.reporter_uid) || isPlatformAdmin();
      allow create: if isAuth() && request.resource.data.reporter_uid == request.auth.uid;
      allow update: if isPlatformAdmin();
      allow delete: if isPlatformAdmin();
    }

    // ─── Auditoria ────────────────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read: if isPlatformAdmin();
      allow create: if isAuth();
      allow update, delete: if false; // Imutável
    }

    // ─── Configurações da plataforma (feature flags, doc único `global`) ───────
    match /platform_settings/{docId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    // ─── Fase 21: Painel de Saúde da Plataforma (admin master) ─────────────
    // Coleções de observabilidade/admin. Apenas platform_admin lê; escrita
    // é via Cloud Function (admin SDK) para os snapshots, e via admin
    // client para billing/alert_config.
    match /platform_health_snapshots/{snapshotId} {
      allow read: if isAuth() && isPlatformAdmin();
      allow write: if false; // só Cloud Function (platformHealthCron)
    }

    match /platform_alert_config/{configId} {
      allow read: if isAuth() && isPlatformAdmin();
      allow create, update, delete: if isAuth() && isPlatformAdmin();
    }

    match /platform_alert_events/{eventId} {
      allow read: if isAuth() && isPlatformAdmin();
      // Escrita só pela Cloud Function (adminAlerts) e pela trigger
      // server-side via adminAlertsService.evaluateAlerts.
      allow write: if false;
    }

    match /platform_billing/{periodId} {
      allow read: if isAuth() && isPlatformAdmin();
      allow create, update: if isAuth() && isPlatformAdmin();
      allow delete: if false; // imutável
    }

    // function_invocations + slow_queries: instrumentação interna.
    // Apenas Cloud Function escreve (admin SDK); platform_admin lê.
    match /function_invocations/{invocationId} {
      allow read: if isAuth() && isPlatformAdmin();
      allow write: if false;
    }

    match /slow_queries/{queryId} {
      allow read: if isAuth() && isPlatformAdmin();
      allow write: if false;
    }

    match /deploys/{deployId} {
      allow read: if isAuth() && isPlatformAdmin();
      allow write: if false; // Cloud Function / CI only
    }

    // ─── Comunidades (entidade editorial/global) ───────────────────────────────
    match /communities/{communityId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    // ─── Clubes (comunidade) ────────────────────────────────────────────────────
    match /clubs/{clubId} {
      allow read: if true; // Diretório e detalhe públicos
      allow create: if isAuth() && request.resource.data.created_by == request.auth.uid;
      // `created_by` é o proprietário (dono de todas as permissões, protegido
      // contra remoção/rebaixamento — ver domain/permissions.js) e não pode
      // ser trocado por um admin comum, só por um platform_admin.
      allow update: if isPlatformAdmin() ||
        (isClubOwnerOrAdmin(clubId) && request.resource.data.get('created_by', resource.data.created_by) == resource.data.created_by) ||
        (isClubMember(clubId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['member_count', 'updated_at']));
      allow delete: if isClubOwnerOrAdmin(clubId) || isPlatformAdmin();

      // ─── Fase 5: Subcoleção `integrations/google_forms` ────────────
      // Config por abrigo da integração com Google Forms. Plataforma admin
      // tem acesso amplo (debug); abrigo só lê/escreve a sua própria.
      match /integrations/google_forms {
        allow read: if isAuth() && (
          isPlatformAdmin() ||
          isClubOwnerOrAdmin(clubId) ||
          hasClubPermission(clubId, 'integrations')
        );
        allow create, update: if isAuth() && (
          isPlatformAdmin() ||
          isClubOwnerOrAdmin(clubId) ||
          hasClubPermission(clubId, 'integrations')
        );
        allow delete: if isAuth() && isPlatformAdmin();
      }

      // ─── Fase 3: Subcoleção `adoption_workflow` (multi-tenant) ──────
      // Cada application pertence a um abrigo (`shelter_club_id` redundante
      // com a path para defense-in-depth). Read/write controlado.
      //
      // - read: abrigo dono (admin/owner/members com permissão 'animals')
      //         + o próprio applicant_uid (vê seu pedido)
      //         + platform_admin
      // - create: applicant (qualquer user logado). `shelter_club_id`
      //           DEVE ser o clubId da path. Status só pode ser 'applied'.
      // - update: abrigo (decisão) ou applicant (cancel/withdraw).
      //           `shelter_club_id` e `applicant_uid` são IMUTÁVEIS.
      // - delete: só platform_admin.
      match /adoption_workflow/{applicationId} {
        allow read: if isAuth() && (
          isPlatformAdmin() ||
          isClubOwnerOrAdmin(clubId) ||
          canEditClubPets(clubId) ||
          hasClubPermission(clubId, 'animals') ||
          // O próprio applicant pode ler seu pedido
          resource.data.applicant_uid == request.auth.uid
        );
        allow create: if isAuth() && (
          // shelter_club_id deve bater com a path
          request.resource.data.shelter_club_id == clubId &&
          // applicant_uid é o próprio usuário
          request.resource.data.applicant_uid == request.auth.uid &&
          // Status inicial é sempre 'applied'
          request.resource.data.status == 'applied' &&
          // pet_id é obrigatório
          request.resource.data.pet_id is string &&
          request.resource.data.pet_id.size() > 0
        );
        allow update: if isAuth() && (
          // shelter_club_id e applicant_uid IMUTÁVEIS
          request.resource.data.shelter_club_id == resource.data.shelter_club_id &&
          request.resource.data.applicant_uid == resource.data.applicant_uid &&
          // abrigo OU applicant podem atualizar
          (isPlatformAdmin() ||
           isClubOwnerOrAdmin(clubId) ||
           canEditClubPets(clubId) ||
           hasClubPermission(clubId, 'animals') ||
           resource.data.applicant_uid == request.auth.uid)
        );
        allow delete: if isAuth() && isPlatformAdmin();
      }

      // ─── Fase 6: Subcoleção `post_adoption` (plano de pós-adoção) ──
      match /post_adoption/{postAdoptionId} {
        allow read: if isAuth() && (
          isPlatformAdmin() ||
          isClubOwnerOrAdmin(clubId) ||
          canEditClubPets(clubId) ||
          hasClubPermission(clubId, 'animals') ||
          // O próprio adotante pode ler seu plano
          resource.data.adopter_uid == request.auth.uid
        );
        // Apenas Cloud Function (admin SDK) cria — sem permissão direta
        // para client. O abrigo não cria manualmente.
        allow create: if isAuth() && false;
        allow update: if isAuth() && (
          isPlatformAdmin() ||
          isClubOwnerOrAdmin(clubId) ||
          canEditClubPets(clubId) ||
          hasClubPermission(clubId, 'animals') ||
          // Adotante pode marcar como devolvido/pausa
          resource.data.adopter_uid == request.auth.uid
        );
        allow delete: if isAuth() && isPlatformAdmin();
      }

      // ─── Fase 6: Subcoleção `kanban_tasks` (materializadas pelo CRON) ──
      match /kanban_tasks/{taskId} {
        allow read: if isAuth() && (
          isPlatformAdmin() ||
          isClubOwnerOrAdmin(clubId) ||
          hasClubPermission(clubId, 'animals') ||
          // Adotante vê as tasks dele
          resource.data.adopter_uid == request.auth.uid
        );
        // Apenas Cloud Function (admin SDK) cria tasks
        allow create: if isAuth() && false;
        allow update: if isAuth() && (
          isPlatformAdmin() ||
          isClubOwnerOrAdmin(clubId) ||
          hasClubPermission(clubId, 'animals') ||
          // Adotante pode completar/skip
          resource.data.adopter_uid == request.auth.uid
        );
        allow delete: if isAuth() && isPlatformAdmin();
      }

      // ─── Fase 7: Subcoleção `fosters` (Lares Temporários) ───────────
      // Multi-tenant. Cada placement = (abrigo, pet, LT) com prazo.
      match /fosters/{fosterId} {
        allow read: if isAuth() && (
          isPlatformAdmin() ||
          isClubOwnerOrAdmin(clubId) ||
          canEditClubPets(clubId) ||
          hasClubPermission(clubId, 'animals') ||
          // O próprio LT (foster_uid) pode ler seu placement
          resource.data.foster_uid == request.auth.uid
        );
        allow create: if isAuth() && (
          isPlatformAdmin() ||
          isClubOwnerOrAdmin(clubId) ||
          canEditClubPets(clubId) ||
          hasClubPermission(clubId, 'animals')
        );
        allow update: if isAuth() && (
          isPlatformAdmin() ||
          isClubOwnerOrAdmin(clubId) ||
          canEditClubPets(clubId) ||
          hasClubPermission(clubId, 'animals') ||
          // LT pode aceitar (pending → active) ou cancelar antes de começar
          resource.data.foster_uid == request.auth.uid
        );
        allow delete: if isAuth() && isPlatformAdmin();
      }

      // ─── Fase 11: Subcoleção `exhibitions` (Vitrines / Eventos) ───────
      // Multi-tenant. Cada vitrine = (abrigo, organizador) com janela de
      // tempo, local (lat/lng), animais (internos + externos de outros
      // abrigos), escalas e log do destino de cada animal pós-evento.
      //
      // - read: abrigo (admin/owner/animals) + o próprio organizador +
      //   qualquer co-organizador
      // - create: abrigo (admin/owner/animals) — organizer_uid vem
      //   obrigatório e vira imutável (write-once)
      // - update: abrigo (status, pets, etc) — organizer_uid e
      //   shelter_club_id são IMUTÁVEIS, status só aceita valores
      //   válidos (scheduled/active/completed/cancelled)
      // - delete: só platform_admin
      match /exhibitions/{exhibitionId} {
        allow read: if isAuth() && (
          isPlatformAdmin() ||
          isClubOwnerOrAdmin(clubId) ||
          canEditClubPets(clubId) ||
          hasClubPermission(clubId, 'animals') ||
          // Organizador e co-organizadores podem ler
          resource.data.organizer_uid == request.auth.uid ||
          request.auth.uid in resource.data.get('co_organizers_uids', [])
        );
        allow create: if isAuth() && (
          isPlatformAdmin() ||
          isClubOwnerOrAdmin(clubId) ||
          canEditClubPets(clubId) ||
          hasClubPermission(clubId, 'animals')
        ) && request.resource.data.shelter_club_id == clubId
          && request.resource.data.organizer_uid is string
          && request.resource.data.organizer_uid.size() > 0
          && request.resource.data.status == 'scheduled';
        allow update: if isAuth() && (
          isPlatformAdmin() ||
          isClubOwnerOrAdmin(clubId) ||
          canEditClubPets(clubId) ||
          hasClubPermission(clubId, 'animals')
        ) && request.resource.data.shelter_club_id == resource.data.shelter_club_id
          && request.resource.data.organizer_uid == resource.data.organizer_uid
          && request.resource.data.status in ['scheduled', 'active', 'completed', 'cancelled'];
        allow delete: if isAuth() && isPlatformAdmin();

        // ─── Subcoleção `shifts` (Escalas da vitrine) ──────────────
        // Cada escala = (vitrine, role, janela, vagas totais/preenchidas).
        match /shifts/{shiftId} {
          allow read: if isAuth() && (
            isPlatformAdmin() ||
            isClubOwnerOrAdmin(clubId) ||
            canEditClubPets(clubId) ||
            hasClubPermission(clubId, 'animals')
          );
          allow create: if isAuth() && (
            isPlatformAdmin() ||
            isClubOwnerOrAdmin(clubId) ||
            canEditClubPets(clubId) ||
            hasClubPermission(clubId, 'animals')
          ) && request.resource.data.shelter_club_id == clubId
            && request.resource.data.exhibition_id == exhibitionId
            && request.resource.data.slots_total is int
            && request.resource.data.slots_total > 0
            && request.resource.data.slots_filled == 0;
          allow update: if isAuth() && (
            isPlatformAdmin() ||
            isClubOwnerOrAdmin(clubId) ||
            canEditClubPets(clubId) ||
            hasClubPermission(clubId, 'animals')
          ) && request.resource.data.shelter_club_id == resource.data.shelter_club_id
            && request.resource.data.exhibition_id == resource.data.exhibition_id
            && request.resource.data.slots_filled <= request.resource.data.slots_total;
          allow delete: if isAuth() && isPlatformAdmin();
        }

        // ─── Subcoleção `post_event_log` (Destino de cada animal) ──
        // Um log por pet (interno ou externo). Idempotente via query na
        // service layer; rules não deduplicam (responsabilidade do service).
        match /post_event_log/{logId} {
          allow read: if isAuth() && (
            isPlatformAdmin() ||
            isClubOwnerOrAdmin(clubId) ||
            canEditClubPets(clubId) ||
            hasClubPermission(clubId, 'animals')
          );
          allow create: if isAuth() && (
            isPlatformAdmin() ||
            isClubOwnerOrAdmin(clubId) ||
            canEditClubPets(clubId) ||
            hasClubPermission(clubId, 'animals')
          ) && request.resource.data.shelter_club_id == clubId
            && request.resource.data.exhibition_id == exhibitionId
            && request.resource.data.pet_id is string
            && request.resource.data.pet_id.size() > 0
            && request.resource.data.destination in ['returned_to_shelter', 'adopted', 'transferred', 'died']
            && request.resource.data.pet_origin in ['internal', 'external']
            && request.resource.data.logged_by_uid == request.auth.uid;
          allow update: if isAuth() && (
            isPlatformAdmin() ||
            isClubOwnerOrAdmin(clubId) ||
            canEditClubPets(clubId) ||
            hasClubPermission(clubId, 'animals')
          ) && request.resource.data.shelter_club_id == resource.data.shelter_club_id
            && request.resource.data.exhibition_id == resource.data.exhibition_id;
          allow delete: if isAuth() && isPlatformAdmin();
        }
      }

      // ─── Fase 13: Subcoleção `volunteers` (rostagem per-shelter) ─────────
      // Multi-tenant. Cada doc = (abrigo, voluntário) com status da rostagem
      // e background check PER-SHELTER (não portável entre abrigos).
      // Id determinista = volunteerUid (1 doc por par abrigo+voluntário).
      //
      // - read: abrigo (admin/owner/animals) + o próprio voluntário
      // - create: abrigo (admin/owner/animals) OU o próprio voluntário
      //   (auto-join, com snapshot do aceite do termo vindo do perfil global)
      // - update: abrigo (status da rostagem, BG check) OU o próprio
      //   voluntário (pausar/retomar/left). shelter_club_id e
      //   volunteer_uid são IMUTÁVEIS.
      // - delete: só platform_admin (hard delete)
      match /volunteers/{volunteerUid} {
        allow read: if isAuth() && (
          isPlatformAdmin() ||
          isClubOwnerOrAdmin(clubId) ||
          canEditClubPets(clubId) ||
          hasClubPermission(clubId, 'animals') ||
          // O próprio voluntário pode ler sua rostagem
          volunteerUid == request.auth.uid
        );
        allow create: if isAuth() && (
          request.resource.data.shelter_club_id == clubId &&
          request.resource.data.volunteer_uid is string &&
          request.resource.data.volunteer_uid.size() > 0 &&
          request.resource.data.volunteer_name is string &&
          request.resource.data.volunteer_name.size() >= 2 &&
          request.resource.data.terms_accepted_at is string &&
          (isPlatformAdmin() ||
           isClubOwnerOrAdmin(clubId) ||
           canEditClubPets(clubId) ||
           hasClubPermission(clubId, 'animals') ||
           // Auto-join: o próprio voluntário pode se adicionar
           volunteerUid == request.auth.uid)
        );
        allow update: if isAuth() && (
          // shelter_club_id e volunteer_uid IMUTÁVEIS
          request.resource.data.shelter_club_id == resource.data.shelter_club_id &&
          request.resource.data.volunteer_uid == resource.data.volunteer_uid &&
          (isPlatformAdmin() ||
           isClubOwnerOrAdmin(clubId) ||
           canEditClubPets(clubId) ||
           hasClubPermission(clubId, 'animals') ||
           // O próprio voluntário pode pausar/retomar/sair
           volunteerUid == request.auth.uid)
        );
        allow delete: if isAuth() && isPlatformAdmin();
      }

      // ─── Fase 13: Subcoleção `volunteer_participations` (turnos) ─────────
      // Multi-tenant. Cada doc = (abrigo, voluntário, evento) com check-in/out.
      // exhibition_id é FK opcional para Fase 11 (vitrines) — string livre
      // aqui, sem dependência.
      //
      // - read: abrigo (admin/owner/animals) + o próprio voluntário
      // - create: abrigo (admin/owner/animals)
      // - update: abrigo (notas, event_date) OU o próprio voluntário
      //   (check-in / check-out self-service)
      // - delete: só platform_admin
      match /volunteer_participations/{participationId} {
        allow read: if isAuth() && (
          isPlatformAdmin() ||
          isClubOwnerOrAdmin(clubId) ||
          canEditClubPets(clubId) ||
          hasClubPermission(clubId, 'animals') ||
          // O próprio voluntário pode ler suas participações
          resource.data.volunteer_uid == request.auth.uid
        );
        allow create: if isAuth() && (
          request.resource.data.shelter_club_id == clubId &&
          request.resource.data.volunteer_uid is string &&
          request.resource.data.volunteer_uid.size() > 0 &&
          request.resource.data.volunteer_name is string &&
          request.resource.data.event_type is string &&
          request.resource.data.event_label is string &&
          request.resource.data.event_date is string &&
          request.resource.data.role is string &&
          (isPlatformAdmin() ||
           isClubOwnerOrAdmin(clubId) ||
           canEditClubPets(clubId) ||
           hasClubPermission(clubId, 'animals'))
        );
        allow update: if isAuth() && (
          // shelter_club_id, volunteer_uid, event_type IMUTÁVEIS
          request.resource.data.shelter_club_id == resource.data.shelter_club_id &&
          request.resource.data.volunteer_uid == resource.data.volunteer_uid &&
          request.resource.data.event_type == resource.data.event_type &&
          (isPlatformAdmin() ||
           isClubOwnerOrAdmin(clubId) ||
           canEditClubPets(clubId) ||
           hasClubPermission(clubId, 'animals') ||
           // Self-service check-in/out
           resource.data.volunteer_uid == request.auth.uid)
        );
        allow delete: if isAuth() && isPlatformAdmin();
      }
    }

    match /club_members/{memberId} {
      allow read: if isAuth();
      // Autoingresso (código de convite / aceitar convite) só pode criar a
      // própria associação como membro comum, sem `permissions` — impede que
      // o usuário se autopromova a admin ou se autoconceda permissões
      // granulares (animals/finance/donations/feed/team) direto pelo SDK.
      // Exceção: o próprio criador do clube (clubs.created_by) pode
      // autocriar sua associação de admin — é exatamente o passo 2 do fluxo
      // de criação de clube (createClub), sequencial e sem outro admin ainda
      // para fazer essa criação por ele. Segue sem `permissions`.
      // Qualquer outro papel/permissão só um admin existente pode conceder.
      allow create: if isAuth() && (
        (request.resource.data.user_id == request.auth.uid &&
          request.resource.data.get('role', 'member') == 'member' &&
          !('permissions' in request.resource.data)) ||
        (request.resource.data.user_id == request.auth.uid &&
          request.resource.data.get('role', '') == 'admin' &&
          !('permissions' in request.resource.data) &&
          isClubOwnerUid(request.resource.data.club_id, request.auth.uid)) ||
        isClubOwnerOrAdmin(request.resource.data.club_id) ||
        isPlatformAdmin()
      );
      // Proprietário é protegido: nem outro admin pode alterar seu papel/
      // permissões, nem removê-lo — só ele mesmo (saindo do clube) ou um
      // platform_admin.
      allow update: if isPlatformAdmin() ||
        (isClubOwnerOrAdmin(resource.data.club_id) && !isClubOwnerUid(resource.data.club_id, resource.data.user_id));
      allow delete: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        (isClubOwnerOrAdmin(resource.data.club_id) && !isClubOwnerUid(resource.data.club_id, resource.data.user_id)) ||
        isPlatformAdmin()
      );
    }

    match /club_join_requests/{requestId} {
      allow read: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        isClubOwnerOrAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
      allow create: if isAuth() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isClubOwnerOrAdmin(resource.data.club_id) || isPlatformAdmin();
    }

    match /club_member_invites/{inviteId} {
      allow read: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        isClubOwnerOrAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
      allow create: if isAuth() && isClubOwnerOrAdmin(request.resource.data.club_id) && request.resource.data.invited_by == request.auth.uid;
      allow update: if isAuth() && resource.data.user_id == request.auth.uid;
      allow delete: if isClubOwnerOrAdmin(resource.data.club_id) || isPlatformAdmin();
    }

    match /club_events/{eventId} {
      allow read: if isAuth() && (
        (resource.data.visibility == 'public' && isClubMember(resource.data.club_id)) ||
        hasEventInvite(eventId) ||
        isClubOwnerOrAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
      allow create: if isAuth() && isClubMember(request.resource.data.club_id) && request.resource.data.created_by == request.auth.uid;
      allow update, delete: if isAuth() && (
        resource.data.created_by == request.auth.uid ||
        isClubOwnerOrAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );

      match /dates/{dateId} {
        allow read: if isClubMember(eventClubId(eventId)) || hasEventInvite(eventId) || isPlatformAdmin();
        allow write: if isClubMember(eventClubId(eventId)) || isPlatformAdmin();
      }
      match /date_rsvps/{rsvpId} {
        allow read: if isClubMember(eventClubId(eventId)) || hasEventInvite(eventId) || isPlatformAdmin();
        allow write: if isClubMember(eventClubId(eventId)) || hasEventInvite(eventId) || isPlatformAdmin();
      }
      match /messages/{messageId} {
        allow read: if isClubMember(eventClubId(eventId)) || hasEventInvite(eventId) || isPlatformAdmin();
        allow create: if isAuth() && (isClubMember(eventClubId(eventId)) || hasEventInvite(eventId))
          && request.resource.data.sender_id == request.auth.uid;
        allow update: if isAuth() && resource.data.sender_id == request.auth.uid;
        allow delete: if isAuth() && (
          resource.data.sender_id == request.auth.uid ||
          isClubOwnerOrAdmin(eventClubId(eventId)) ||
          isPlatformAdmin()
        );
      }
      match /participants/{participantId} {
        allow read: if isClubMember(eventClubId(eventId)) || hasEventInvite(eventId) || isPlatformAdmin();
        allow write: if isClubMember(eventClubId(eventId)) || hasEventInvite(eventId) || isPlatformAdmin();
      }
    }

    // Legado: RSVP de evento em coleção de nível superior (mantido por compatibilidade).
    match /club_event_rsvps/{rsvpId} {
      allow read: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        isClubOwnerOrAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
      allow create, update: if isAuth() && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        isClubOwnerOrAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
    }

    match /event_invites/{inviteId} {
      allow read: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        resource.data.invited_by == request.auth.uid ||
        isClubOwnerOrAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
      allow create: if isAuth() && (
        request.resource.data.user_id == request.auth.uid ||
        request.resource.data.invited_by == request.auth.uid
      );
      allow update: if isAuth() && resource.data.user_id == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        resource.data.invited_by == request.auth.uid ||
        isClubOwnerOrAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
    }

    match /club_posts/{postId} {
      allow read: if isClubMember(resource.data.club_id) || isPlatformAdmin();
      allow create: if isAuth() && isClubMember(request.resource.data.club_id) && request.resource.data.author_id == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.author_id == request.auth.uid ||
        isClubOwnerOrAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
    }

    // ─── Chamados de doação (campanhas) de uma organização ─────────────────────
    match /club_campaigns/{campaignId} {
      allow read: if true; // Visível publicamente (transparência de arrecadação)
      allow create: if isAuth() && (
        isClubOwnerOrAdmin(request.resource.data.club_id) || hasClubPermission(request.resource.data.club_id, 'donations')
      );
      // `club_id` é imutável no update — impede que quem só tem permissão
      // `donations` na organização A "mude de dono" uma campanha para a
      // organização B (o campo não está na allow-list de updateClubCampaign,
      // mas a regra precisa recusar mesmo assim para quem usa o SDK direto).
      allow update: if isAuth() && request.resource.data.club_id == resource.data.club_id && (
        isClubOwnerOrAdmin(resource.data.club_id) || hasClubPermission(resource.data.club_id, 'donations') || isPlatformAdmin()
      );
      allow delete: if isAuth() && (
        isClubOwnerOrAdmin(resource.data.club_id) || hasClubPermission(resource.data.club_id, 'donations') || isPlatformAdmin()
      );
    }

    // ─── Prestação de contas (lançamentos financeiros) de uma organização ──────
    match /club_ledger/{entryId} {
      allow read: if isAuth() && (
        isClubOwnerOrAdmin(resource.data.club_id) || hasClubPermission(resource.data.club_id, 'finance') || isPlatformAdmin()
      );
      allow create: if isAuth() && (
        isClubOwnerOrAdmin(request.resource.data.club_id) || hasClubPermission(request.resource.data.club_id, 'finance')
      );
      // `club_id` imutável no update — mesma razão do club_campaigns acima.
      allow update: if isAuth() && request.resource.data.club_id == resource.data.club_id && (
        isClubOwnerOrAdmin(resource.data.club_id) || hasClubPermission(resource.data.club_id, 'finance') || isPlatformAdmin()
      );
      allow delete: if isAuth() && (
        isClubOwnerOrAdmin(resource.data.club_id) || hasClubPermission(resource.data.club_id, 'finance') || isPlatformAdmin()
      );
    }

    match /club_forum_threads/{threadId} {
      allow read: if isClubMember(resource.data.club_id) || isPlatformAdmin();
      allow create: if isAuth() && isClubMember(request.resource.data.club_id) && request.resource.data.author_id == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.author_id == request.auth.uid ||
        isClubOwnerOrAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );
      allow delete: if isAuth() && (
        resource.data.author_id == request.auth.uid ||
        isClubOwnerOrAdmin(resource.data.club_id) ||
        isPlatformAdmin()
      );

      match /comments/{commentId} {
        allow read: if isClubMember(resource.data.club_id) || isPlatformAdmin();
        allow create: if isAuth() && isClubMember(request.resource.data.club_id) && request.resource.data.author_id == request.auth.uid;
        allow update: if isAuth() && resource.data.author_id == request.auth.uid;
        allow delete: if isAuth() && (
          resource.data.author_id == request.auth.uid ||
          isClubOwnerOrAdmin(resource.data.club_id) ||
          isPlatformAdmin()
        );
      }
      match /poll_votes/{voteUid} {
        allow read: if isClubMember(resource.data.club_id) || isPlatformAdmin();
        allow create, update: if isAuth() && voteUid == request.auth.uid && isClubMember(request.resource.data.club_id);
        allow delete: if isAuth() && voteUid == request.auth.uid;
      }
    }

    // =========================================================================
    // COMUNIDADES E FÓRUNS
    // =========================================================================
    
    match /communities/{communityId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.owner_id == request.auth.uid;
      // Update pelo owner: NÃO pode trocar owner_id (apenas platform_admin).
      // Exceção: "claim" de comunidade órfã (owner_id legado === null) —
      // o user pode se declarar dono UMA VEZ (resource.data.owner_id == null
      // && request.resource.data.owner_id == auth.uid). Depois disso, o
      // user passa a ser o owner oficial e o caminho normal se aplica.
      allow update: if isAuth() && (
        (request.auth.uid == resource.data.owner_id
          && request.resource.data.owner_id == resource.data.owner_id)
        || (resource.data.owner_id == null
          && request.resource.data.owner_id == request.auth.uid)
        || isPlatformAdmin()
      );
      allow delete: if isPlatformAdmin();
    }
    
    match /community_members/{memberId} {
      allow read: if true;
      // Defeito de segurança: 'create, update, delete: if isAuth()' permitia
      // que QUALQUER usuário autenticado modificasse memberships (incluindo
      // se promover a admin ou remover o criador). Agora:
      //  - create: o user_id do doc DEVE ser o próprio usuário OU um admin
      //    da comunidade criando outro membro (convite).
      //  - update: só admin da comunidade OU o próprio user_id do doc
      //    (para auto-atualizações como 'last_seen'). O campo 'role' só
      //    pode ser alterado por admin.
      //  - delete: admin OU o próprio user_id (sair da comunidade).
      allow create: if isAuth() && (
        request.resource.data.user_id == request.auth.uid ||
        canManageCommunity(get(/databases/$(database)/documents/communities/$(communityId)).data)
      );
      allow update: if isAuth() && (
        canManageCommunity(get(/databases/$(database)/documents/communities/$(communityId)).data) ||
        (resource.data.user_id == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['last_seen', 'updated_at']))
      );
      allow delete: if isAuth() && (
        canManageCommunity(get(/databases/$(database)/documents/communities/$(communityId)).data) ||
        resource.data.user_id == request.auth.uid
      );
    }
    
    match /community_posts/{postId} {
      allow read: if true;
      // Antes: 'create: if isAuth()' permitia QUALQUER usuário criar posts
      // em QUALQUER comunidade. Agora exige ser membro OU admin da
      // comunidade-alvo.
      allow create: if isAuth() && (
        canManageCommunity(get(/databases/$(database)/documents/communities/$(communityId)).data) ||
        isCommunityMember(communityId)
      );
      allow update: if isAuth() && (
        request.auth.uid == resource.data.author_id ||
        canManageCommunity(get(/databases/$(database)/documents/communities/$(communityId)).data)
      );
      allow delete: if isAuth() && (
        request.auth.uid == resource.data.author_id ||
        canManageCommunity(get(/databases/$(database)/documents/communities/$(communityId)).data) ||
        isPlatformAdmin()
      );
    }
    
    match /community_post_likes/{likeId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAuth() && resource.data.user_id == request.auth.uid;
    }
    
    match /community_post_comments/{commentId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && (isPlatformAdmin() || request.auth.uid == resource.data.author_id);
    }
    
    match /community_events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAuth();
    }
    
    match /community_forum_threads/{threadId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && (
        isPlatformAdmin() ||
        request.auth.uid == resource.data.author_id ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes_count', 'messages_count', 'updated_at']))
      );
      allow delete: if isAuth() && (isPlatformAdmin() || request.auth.uid == resource.data.author_id);

      match /likes/{likeId} {
        allow read: if true;
        allow create: if isAuth();
        allow delete: if isAuth() && likeId == request.auth.uid;
      }
      match /poll_votes/{voteUid} {
        allow read: if true;
        allow create, update: if isAuth() && voteUid == request.auth.uid;
        allow delete: if isAuth() && voteUid == request.auth.uid;
      }
    }
    
    match /community_forum_messages/{messageId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && (
        isPlatformAdmin() ||
        request.auth.uid == resource.data.author_id ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes_count']))
      );
      allow delete: if isAuth() && (isPlatformAdmin() || request.auth.uid == resource.data.author_id);

      match /likes/{likeId} {
        allow read: if true;
        allow create: if isAuth();
        allow delete: if isAuth() && likeId == request.auth.uid;
      }
      match /poll_votes/{voteUid} {
        allow read: if true;
        allow create, update: if isAuth() && voteUid == request.auth.uid;
        allow delete: if isAuth() && voteUid == request.auth.uid;
      }
    }

    // =========================================================================
    // ORGANIZAÇÕES (ONGs) — Novas regras para o módulo de Organizações
    // =========================================================================

    // --- Mural da ONG: posts, likes e comentários ---
    // Posts do mural são visíveis para qualquer pessoa (qualquer user da
    // plataforma). A regra de "se o post permite interação" é aplicada
    // client-side — mas likes/comments são validados pelas regras abaixo.
    match /club_posts/{postId} {
      allow read: if true;
      // Autor precisa ser membro da ONG e dono do `author_id`.
      allow create: if isAuth()
        && isClubMember(request.resource.data.club_id)
        && request.resource.data.author_id == request.auth.uid
        && (
          hasClubPermission(request.resource.data.club_id, 'feed')
          || isClubOwnerOrAdmin(request.resource.data.club_id)
        );
      // Update: autor do post pode editar enquanto ninguém curtiu/comentou,
      // OU admin/equipe com permissão de feed pode editar/excluir.
      allow update: if isAuth() && (
        (resource.data.author_id == request.auth.uid
          && (resource.data.likes_count == null || resource.data.likes_count == 0)
          && (resource.data.comments_count == null || resource.data.comments_count == 0))
        || isClubOwnerOrAdmin(resource.data.club_id)
        || hasClubPermission(resource.data.club_id, 'feed')
        || isPlatformAdmin()
      );
      allow delete: if isAuth() && (
        resource.data.author_id == request.auth.uid
        || isClubOwnerOrAdmin(resource.data.club_id)
        || hasClubPermission(resource.data.club_id, 'feed')
        || isPlatformAdmin()
      );
    }

    // Curtidas no mural da ONG. O id do doc é `${postId}_${uid}` para
    // garantir idempotência (uma curtida por usuário por post).
    // A validação de "o post permite curtidas" é feita no client-side
    // (canLikeClubPost) — mesma estratégia adotada em `community_post_likes`
    // — para evitar um `get()` extra dentro da transação.
    match /club_post_likes/{likeId} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAuth() && resource.data.user_id == request.auth.uid;
    }

    // Comentários no mural da ONG.
    match /club_post_comments/{commentId} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.author_id == request.auth.uid
        // Só permite comentar se o post permitir.
        && get(/databases/$(database)/documents/club_posts/$(request.resource.data.post_id)).data.get('allow_comments', false) == true;
      // Edição: apenas o próprio autor pode editar (e só texto). Exclusão:
      // o autor, admin da ONG, ou alguém com permissão 'feed'.
      allow update: if isAuth() && (
        request.auth.uid == resource.data.author_id
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'updated_at'])
      );
      allow delete: if isAuth() && (
        request.auth.uid == resource.data.author_id
        || isClubOwnerOrAdmin(resource.data.club_id)
        || hasClubPermission(resource.data.club_id, 'feed')
        || isPlatformAdmin()
      );
    }

    // --- Chamados de doação (v2 — com PIX, QR e comprovantes) ---
    // Substitui `club_campaigns` para os novos fluxos. A coleção legada
    // continua existindo e tem suas próprias regras acima.
    match /club_donations/{donationId} {
      allow read: if true; // Transparência pública
      allow create: if isAuth() && (
        isClubOwnerOrAdmin(request.resource.data.club_id)
        || hasClubPermission(request.resource.data.club_id, 'donations')
      );
      allow update: if isAuth()
        && request.resource.data.club_id == resource.data.club_id
        && (
          isClubOwnerOrAdmin(resource.data.club_id)
          || hasClubPermission(resource.data.club_id, 'donations')
          || isPlatformAdmin()
        );
      allow delete: if isAuth() && (
        isClubOwnerOrAdmin(resource.data.club_id)
        || hasClubPermission(resource.data.club_id, 'donations')
        || isPlatformAdmin()
      );
    }

    // Comprovantes de contribuição enviados pelo público.
    match /club_donation_receipts/{receiptId} {
      // Quem pode ver: o próprio usuário que enviou, a equipe da ONG
      // (admin ou permissão donations) e platform_admin.
      allow read: if isAuth() && (
        resource.data.user_id == request.auth.uid
        || isClubOwnerOrAdmin(resource.data.club_id)
        || hasClubPermission(resource.data.club_id, 'donations')
        || isPlatformAdmin()
      );
      // Qualquer usuário autenticado pode enviar um comprovante, desde que:
      //  - o user_id seja ele mesmo;
      //  - a doação tenha `enable_receipt_upload == true`.
      allow create: if isAuth()
        && request.resource.data.user_id == request.auth.uid
        && get(/databases/$(database)/documents/club_donations/$(request.resource.data.donation_id)).data.get('enable_receipt_upload', false) == true;
      // Apenas a equipe da ONG pode atualizar o status (confirmar/rejeitar).
      // Restringe os campos alteráveis a status/updated_at/reviewed_by.
      allow update: if isAuth() && (
        (isClubOwnerOrAdmin(resource.data.club_id)
         || hasClubPermission(resource.data.club_id, 'donations')
         || isPlatformAdmin())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['status', 'updated_at', 'reviewed_by', 'reviewed_at', 'admin_note']
        )
      );
      allow delete: if isAuth() && (
        isClubOwnerOrAdmin(resource.data.club_id)
        || hasClubPermission(resource.data.club_id, 'donations')
        || isPlatformAdmin()
        || resource.data.user_id == request.auth.uid
      );
    }

    // --- Categorias configuráveis da prestação de contas ---
    match /club_ledger_categories/{categoryId} {
      // Categorias customizadas são lidas por qualquer membro da ONG.
      allow read: if isAuth() && (
        isClubMember(resource.data.club_id) || isPlatformAdmin()
      );
      allow create, update, delete: if isAuth() && (
        isClubOwnerOrAdmin(request.resource.data.club_id)
        || hasClubPermission(request.resource.data.club_id, 'finance')
        || isPlatformAdmin()
      );
    }

    // --- Chat dedicado entre um usuário e a ONG ---
    // A thread é criada quando o primeiro user inicia a conversa. A
    // equipe da ONG entra como participante adicional ao responder.
    match /club_chat_threads/{threadId} {
      allow read: if isAuth() && (
        resource.data.user_id == request.auth.uid
        || isClubMember(resource.data.club_id)
        || isPlatformAdmin()
      );
      // O usuário cria a thread para si mesmo, vinculado a uma ONG.
      // O status começa como 'open' e o user_id é o caller.
      allow create: if isAuth()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.club_id != null;
      // Update: o user pode fechar a própria thread; a ONG pode mudar
      // status (open/closed/archived).
      allow update: if isAuth() && (
        (resource.data.user_id == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updated_at', 'last_message_at']))
        || isClubOwnerOrAdmin(resource.data.club_id)
        || hasClubPermission(resource.data.club_id, 'feed')
        || hasClubPermission(resource.data.club_id, 'team')
        || isPlatformAdmin()
      );
      allow delete: if isAuth() && (
        isClubOwnerOrAdmin(resource.data.club_id) || isPlatformAdmin()
      );

      // Mensagens da thread. As mensagens são sempre escritas pelo
      // próprio autor (`sender_id == auth.uid`).
      match /messages/{messageId} {
        allow read: if isAuth() && (
          get(/databases/$(database)/documents/club_chat_threads/$(threadId)).data.user_id == request.auth.uid
          || isClubMember(get(/databases/$(database)/documents/club_chat_threads/$(threadId)).data.club_id)
          || isPlatformAdmin()
        );
        allow create: if isAuth() && request.resource.data.sender_id == request.auth.uid;
        allow update: if isAuth() && request.auth.uid == resource.data.sender_id
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'edited', 'updated_at']);
        allow delete: if isAuth() && (
          request.auth.uid == resource.data.sender_id
          || isClubOwnerOrAdmin(get(/databases/$(database)/documents/club_chat_threads/$(threadId)).data.club_id)
          || isPlatformAdmin()
        );
      }
    }

    // --- Atualização do documento `clubs/{id}` para os novos campos da aba
    //     "Geral" (history, whatsapp_number, chat_enabled, etc.) e para os
    //     campos de privacidade/bio do `club_members/{id}`.
    // A regra `match /clubs/{clubId}` original já permite update por admin;
    // a única coisa nova é permitir que o próprio membro edite a própria
    // bio/privacy/contact (mas NÃO o role/permissions).

    // Permite que um membro edite APENAS seus próprios campos visuais
    // (title, bio, history, whatsapp, phone, privacy_map) — sem mexer em
    // role/permissions, que continuam exclusivos de admin/team.
    match /club_members/{memberId} {
      allow update: if isPlatformAdmin()
        || (isClubOwnerOrAdmin(resource.data.club_id)
            && !isClubOwnerUid(resource.data.club_id, resource.data.user_id))
        || (resource.data.user_id == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
              ['title', 'bio', 'history', 'phone', 'whatsapp', 'photo_url',
               'user_name', 'user_email', 'privacy_map', 'updated_at']
            ));
    }

    // ─── Fase 20: Alertas de Segurança (platform_security_alerts) ──────────
    //
    // Coleção de eventos de segurança (logins suspeitos, alterações
    // de regras, picos de billing, rate limit, RLS denied, manuais).
    // Escrita SOMENTE pela Cloud Function `triggerSecurityAlert`
    // (Admin SDK — o client não tem permissão de escrita).
    // Leitura restrita ao platform_admin.
    //
    // Schema validado em functions/securityAlerts.js:
    //   { type, severity, source, context, created_at, created_by,
    //     resolved, resolved_by, resolved_at, notes }
    match /platform_security_alerts/{alertId} {
      allow read: if isAuth() && isPlatformAdmin();
      allow create, update, delete: if false;  // só Admin SDK / Cloud Function
    }
  }
}
