# Firebase Web SDK config (frontend)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firestore database id (named DB). Defaults to "pickleball" (the dedicated
# Firestore database for this project).
VITE_FIRESTORE_DATABASE_ID=pickleball

# Optional observability
VITE_ENABLE_FIREBASE_ANALYTICS=false
VITE_ENABLE_FIREBASE_PERFORMANCE=false

# Optional emulator suite
VITE_FIREBASE_USE_EMULATORS=false
