# Firebase Web SDK config (frontend)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firestore database id (named DB, not the "(default)" database). Defaults to
# "viralata" (the dedicated Firestore database for this project) if unset.
VITE_FIRESTORE_DATABASE_ID=viralata

# Optional observability
VITE_ENABLE_FIREBASE_ANALYTICS=false
VITE_ENABLE_FIREBASE_PERFORMANCE=false

# Optional emulator suite
VITE_FIREBASE_USE_EMULATORS=false

# PWA (app instalável Android/iOS direto do site, sem lojas).
# Mantenha "false" até validar tudo: com a flag desligada, nenhum service
# worker é registrado e o botão "Baixar o app" não aparece (zero impacto).
VITE_PWA_ENABLED=false

# ─── App Check (Fase 20 — Segurança Avançada) ────────────────────────
# reCAPTCHA v3 site key (frontend). Em dev local, deixe vazio — App
# Check desliga-se via `setTokenAutoRefreshEnabled(false)`.
# Em produção, configure o site key no Firebase Console → App Check
# e cole o valor aqui. O secret do provedor é server-side (Functions).
VITE_RECAPTCHA_SITE_KEY=

# ─── Rate limit (Cloud Functions) ────────────────────────────────────
# Janela em ms para o limiter em memória das Cloud Functions
# (googleFormsWebhook, etc.). Default 60_000 (1 min).
RATE_LIMIT_WINDOW_MS=60000
# Máximo de req por janela por chave (IP). Default 100.
RATE_LIMIT_MAX=100
# Set "true" em testes E2E / local para desligar o limiter. Default off.
RATE_LIMIT_DISABLED=false
