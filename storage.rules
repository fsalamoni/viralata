rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ─── DENY-BY-DEFAULT EXPLÍCITO (Fase 20 — Segurança Avançada) ─────
    // Qualquer path NÃO listado abaixo é rejeitado tanto em leitura
    // quanto em escrita. Mantém o default seguro (Firestore/Storage
    // já negam por padrão) explícito para auditoria — qualquer novo
    // bucket/path precisa adicionar uma regra explícita aqui.

    // Storage rules — Volunteers module (TASK-227)
    // Why: storage.rules previously prohibited application/pdf, blocking:
    //   1. BG check document upload (voluntário sobe RG/certidão)
    //   2. Termo assinado PDF (Lei 14.063/2020 art. 4º §1º prova legal)
    //   3. Certificado de horas PDF (Lei 9.608/1998 + termo v2 §6.1e)
    // Decision: volunteer uploads go in /volunteers/{uid}/ (any auth user uploads, owner reads).
    //            Cloud Functions write to /term_signed/ and /volunteer_certificates/ (immutable).

    // ─── Helpers (TASK-227) ──────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isPlatformAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isClubMemberOfVolunteer(volunteerUid) {
      // TODO(TASK-231): replace with real check via Firestore read.
      // Storage rules cannot do cross-service reads, so for now we
      // allow any authenticated user. Will be tightened once
      // granular volunteer permissions (TASK-219/231) ship.
      return request.auth != null;
    }

    function isClubAdminForUser(volunteerUid) {
      // TODO(TASK-231): same caveat as isClubMemberOfVolunteer above.
      return request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Uploads gerais (pets, denúncias, posts de clube, anexos de fórum/chat).
    // storageService.js grava tudo em `uploads/{uid}/{folder}/...`; dono grava
    // no próprio caminho, leitura pública (fotos/anexos exibidos a outros
    // usuários — feed de pets, mural do clube, fórum, chat).
    //
    // Bloqueia arquivos que NÃO sejam imagem/* ou vídeo/* (defesa contra
    // upload de executáveis, PDFs arbitrários, scripts etc.).
    match /uploads/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 25 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }
    // Pets: qualquer autenticado pode fazer upload, leitura pública.
    // Aceita somente image/* e video/* (Fase 20).
    match /pets/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }
    // Denúncias: apenas o próprio usuário (e platform_admin).
    // Aceita somente image/* e video/* (Fase 20).
    match /reports/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.role == 'platform_admin'
      );
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }
    // Organizações: membros admin (ou platform_admin via token.role).
    // Aceita somente image/* e video/* (Fase 20).
    match /organizations/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }
    // Avatares de usuários: image/* e video/* (Fase 20) — limite 5MB.
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }

    // ─── Voluntários (TASK-227) ─────────────────────────────────────
    // /volunteers/{uid}/**: uploads do próprio voluntário (foto perfil,
    // docs complementares). Aceita image/* + application/pdf (RG/certidão).
    match /volunteers/{userId}/{allPaths=**} {
      allow read: if isOwner(userId) || isClubMemberOfVolunteer(userId) || isPlatformAdmin();
      allow create, update: if isAuth() && isOwner(userId)
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('application/pdf'));
      allow delete: if isOwner(userId) || isPlatformAdmin();
    }

    // /bg_check/{uid}/{fileName}: Background check (PDF único).
    // Voluntário sobe; admin do clube valida visualmente.
    match /bg_check/{userId}/{fileName} {
      allow read: if isAuth() && (isOwner(userId) || isClubAdminForUser(userId) || isPlatformAdmin());
      allow create, update: if isAuth() && isOwner(userId)
        && request.resource.contentType.matches('application/pdf');
      allow delete: if isPlatformAdmin();
    }

    // /term_signed/{uid}/{fileName}: termo assinado (Cloud Function only).
    // Mutações travadas para usuários; somente platform_admin pode remover.
    match /term_signed/{userId}/{fileName} {
      allow read: if isAuth() && isOwner(userId);
      allow create: if false;
      allow update, delete: if isPlatformAdmin();
    }

    // /volunteer_certificates/{uid}/{fileName}: certificado de horas (CF only).
    match /volunteer_certificates/{userId}/{fileName} {
      allow read: if isAuth() && (isOwner(userId) || isClubMemberOfVolunteer(userId) || isPlatformAdmin());
      allow create, update: if false;
      allow delete: if isPlatformAdmin();
    }
  }
}
