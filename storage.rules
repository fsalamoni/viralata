rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ─── DENY-BY-DEFAULT EXPLÍCITO (Fase 20 — Segurança Avançada) ─────
    // Qualquer path NÃO listado abaixo é rejeitado tanto em leitura
    // quanto em escrita. Mantém o default seguro (Firestore/Storage
    // já negam por padrão) explícito para auditoria — qualquer novo
    // bucket/path precisa adicionar uma regra explícita aqui.
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Uploads gerais (pets, denúncias, posts de clube, anexos de fórum/chat).
    // storageService.js grava tudo em `uploads/{uid}/{folder}/...`; dono grava
    // no próprio caminho, leitura pública (fotos/anexos exibidos a outros
    // usuários — feed de pets, mural do clube, fórum, chat).
    //
    // Bloqueia arquivos que NÃO sejam imagem/* ou vídeo/* (defesa contra
    // upload de executáveis, PDFs arbitrários, scripts etc.).
    match /uploads/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 25 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }
    // Pets: qualquer autenticado pode fazer upload, leitura pública.
    // Aceita somente image/* e video/* (Fase 20).
    match /pets/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }
    // Denúncias: apenas o próprio usuário (e platform_admin).
    // Aceita somente image/* e video/* (Fase 20).
    match /reports/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.role == 'platform_admin'
      );
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }
    // Organizações: membros admin (ou platform_admin via token.role).
    // Aceita somente image/* e video/* (Fase 20).
    match /organizations/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }
    // Avatares de usuários: image/* e video/* (Fase 20) — limite 5MB.
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }
  }
}
