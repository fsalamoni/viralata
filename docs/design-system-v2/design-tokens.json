  "accessibility": {
    "description": "Diretrizes de acessibilidade WCAG 2.1 AA.",
    "guidelines": [
      {
        "criterion": "Contraste de cores",
        "requirement": "Mínimo 4.5:1 para texto normal, 3:1 para texto grande",
        "implementation": "Testar com ferramentas de contraste"
      },
      {
        "criterion": "Redução de movimento",
        "requirement": "Respeitar prefers-reduced-motion",
        "implementation": "@media (prefers-reduced-motion: reduce) { * { animation: none !important; } }"
      },
      {
        "criterion": "Foco visível",
        "requirement": "Todos os elementos interativos devem ter foco visível",
        "implementation": "outline: 2px solid hsl(17,72%,43%); outline-offset: 2px;"
      },
      {
        "criterion": "Hierarquia semântica",
        "requirement": "Usar h1, h2, h3 em ordem lógica",
