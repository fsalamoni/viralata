  "gradients": {
    "description": "Usados com moderação — CTAs, marca e superfícies de destaque. Nunca em blocos de texto longos.",
    "items": [
      {
        "id": "brand",
        "name": "Gradiente de marca",
        "css": "linear-gradient(135deg, hsl(17,72%,43%), hsl(40,88%,54%))",
        "direction": "135deg",
        "stops": [
          {"color": "hsl(17,72%,43%)", "position": "0%"},
          {"color": "hsl(40,88%,54%)", "position": "100%"}
        ],
        "usage": "Botões primários, CTA final, ícone do logo",
        "semantics": "primary-gradient"
      },
      {
        "id": "wordmark",
        "name": "Wordmark",
