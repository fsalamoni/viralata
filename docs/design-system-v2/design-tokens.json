  "motion": {
    "description": "Animações sutis que reforçam feedback e hierarquia.",
    "tokens": [
      {
        "id": "entrance",
        "name": "Entrada (fade + slide)",
        "properties": {
          "opacity": "0→1",
          "transform": "translateY(14-16px)→0",
          "duration": "400-600ms",
          "easing": "ease",
          "trigger": "whileInView"
        },
        "usage": "Elementos ao entrar na viewport"
      },
      {
        "id": "pop",
        "name": "Pop (imagem / hero)",
        "properties": {
          "transform": "scale(0.92-0.94)→1",
          "opacity": "0→1",
          "duration": "600ms",
          "easing": "ease"
        },
        "usage": "Imagens, heróis, elementos de destaque"
      },
      {
        "id": "hover-card",
        "name": "Hover em card",
        "properties": {
          "transform": "scale(1.01-1.02)",
          "shadow": "cresce",
          "duration": "300ms",
          "easing": "ease",
          "note": "Nunca tilt 3D"
        },
        "usage": "Cards ao passar mouse"
      },
      {
        "id": "stagger",
        "name": "Stagger em grid",
        "properties": {
          "delay": "70-90ms entre itens",
          "maxItems": "6-8",
          "duration": "400-600ms"
        },
        "usage": "Grids de cards, listas"
      },
      {
        "id": "reduced-motion",
        "name": "Redução de movimento",
        "properties": {
          "mediaQuery": "prefers-reduced-motion: reduce",
          "action": "Desabilitar todas as animações"
        },
        "usage": "Acessibilidade — sempre respeitar"
      }
    ]
  },
  "voice": {
    "description": "Tom de voz: caloroso, empático, direto e acessível.",
    "do": [
      "O Viralata conecta pets que precisam de um lar com famílias que têm amor para dar.",
      "Encontre o pet ideal com base no seu espaço, rotina e estilo de vida.",
      "Denuncie casos de maus-tratos ou abandono. Sua identidade fica confidencial."
    ],
    "avoid": [
      "Nossa plataforma disponibiliza uma solução integrada de matching entre ativos caninos e usuários finais. (jargão corporativo)",
      "Bora adotar um mano peludo?? 🐶🔥 (gírias e emoji em excesso na UI)"
    ],
    "guidelines": [
      "Sempre foco no pet como protagonista",
      "Usar primeira pessoa quando apropriado",
      "Evitar jargão técnico",
      "Ser direto e claro",
      "Reforçar empatia e responsabilidade"
    ]
