{
  "metadata": {
    "name": "Design System Viralata",
    "version": "1.0.0",
    "description": "Design System completo para a plataforma de adoção responsável Viralata. Reúne princípios, fundamentos (cor, tipografia, espaçamento, ícones) e todos os componentes de UI.",
    "organization": "Viralata",
    "repository": "github.com/fsalamoni/viralata",
    "lastUpdated": "2024",
    "status": "active"
  },
  "principles": {
    "description": "As quatro premissas que orientam toda decisão de design na plataforma",
    "items": [
      {
        "id": "clarity",
        "icon": "visibility",
        "title": "Clareza",
        "description": "Hierarquia visual óbvia. Uma ação primária por tela, textos diretos, nunca fazer o usuário adivinhar o próximo passo."
      },
      {
        "id": "intuitive-navigation",
        "icon": "explore",
        "title": "Navegação intuitiva",
        "description": "Estrutura estável (Feed, Abrigos, Voluntários, Comunidade, Chat) — muitas funcionalidades, sempre no mesmo lugar."
      },
      {
        "id": "empathy",
        "icon": "favorite",
        "title": "Empatia & apego",
        "description": "Fotos grandes, tom caloroso, histórias reais. O pet é sempre protagonista visual."
      },
      {
        "id": "organicity",
        "icon": "spa",
        "title": "Organicidade",
        "description": "Formas orgânicas, cantos generosos, superfícies de vidro — nunca aspecto corporativo ou 'feito por IA'."
      }
    ]
  },
