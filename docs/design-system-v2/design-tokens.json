        "id": "sora",
        "family": "Sora",
        "source": "Google Fonts",
        "weights": [600, 700, 800],
        "usage": "Títulos e display",
        "fallback": "sans-serif"
      },
      {
        "id": "manrope",
        "family": "Manrope",
        "source": "Google Fonts",
        "weights": [400, 500, 600, 700, 800],
